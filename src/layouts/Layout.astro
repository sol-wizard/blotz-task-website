---
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';

interface Props {
  title: string;
  description?: string;
  image?: string;
  noindex?: boolean;
  jsonLd?: Record<string, unknown> | Record<string, unknown>[];
}

const siteUrl = 'https://blotztask.com';
const {
  title,
  description = 'BlotzTask is an ADHD-friendly task management app that helps you capture tasks, break work into clear steps, manage deadlines, and plan with less overwhelm.',
  image = '/og-image.svg',
  noindex = false,
  jsonLd,
} = Astro.props;
const locale = Astro.currentLocale ?? 'en';
const currentPath = Astro.url.pathname;
const canonicalUrl = new URL(currentPath, siteUrl).toString();
const alternateBasePath = currentPath.replace(/^\/(en|zh)(?=\/|$)/, '') || '/';
const enUrl = new URL(`/en${alternateBasePath === '/' ? '/' : alternateBasePath}`, siteUrl).toString();
const zhUrl = new URL(`/zh${alternateBasePath === '/' ? '/' : alternateBasePath}`, siteUrl).toString();
const xDefaultUrl = enUrl;
const imageUrl = new URL(image, siteUrl).toString();
const ogLocale = locale === 'zh' ? 'zh_CN' : 'en_US';
const alternateLocale = locale === 'zh' ? 'en_US' : 'zh_CN';
---

<!DOCTYPE html>
<html lang={locale}>
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <meta name="google-site-verification" content="yQ1_GW7zA0g_aJ_XNf3KYzcFvOI3fjsLQixYayV3l6g" />
  <title>{title}</title>
  <meta name="description" content={description} />
  {noindex && <meta name="robots" content="noindex,follow" />}
  <link rel="canonical" href={canonicalUrl} />
  <link rel="alternate" hreflang="en" href={enUrl} />
  <link rel="alternate" hreflang="zh" href={zhUrl} />
  <link rel="alternate" hreflang="x-default" href={xDefaultUrl} />
  <meta property="og:type" content="website" />
  <meta property="og:site_name" content="BlotzTask" />
  <meta property="og:locale" content={ogLocale} />
  <meta property="og:locale:alternate" content={alternateLocale} />
  <meta property="og:title" content={title} />
  <meta property="og:description" content={description} />
  <meta property="og:url" content={canonicalUrl} />
  <meta property="og:image" content={imageUrl} />
  <meta property="og:image:alt" content="BlotzTask ADHD-friendly task management app preview" />
  <meta name="twitter:card" content="summary_large_image" />
  <meta name="twitter:title" content={title} />
  <meta name="twitter:description" content={description} />
  <meta name="twitter:image" content={imageUrl} />
  <link rel="icon" type="image/png" href="/shared-pic/bun-icon.png" />
  <link rel="apple-touch-icon" href="/shared-pic/bun-icon.png" />
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Nunito:wght@400;600;700;800;900&display=swap" rel="stylesheet" />
  {jsonLd && <script type="application/ld+json" set:html={JSON.stringify(jsonLd)} />}
</head>
<body>
  <Nav />
  <slot />
  <Footer />
</body>
</html>

<style is:global>
  :root {
    --green: #96D21B;
    --blue: #3486F3;
    --green-light: #EAF8C7;
    --blue-light: #D5E9FF;
    --bg: #ffffff;
    --text: #1E2140;
    --muted: #6B7280;
    --radius: 20px;
    --shadow: 0 4px 24px rgba(0,0,0,0.08);
    --shadow-lg: 0 8px 40px rgba(0,0,0,0.14);
  }
  *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
  html { scroll-behavior: smooth; }
  body {
    font-family: 'Nunito', 'PingFang SC', 'Microsoft YaHei', system-ui, sans-serif;
    background: var(--bg);
    color: var(--text);
    line-height: 1.6;
  }
  .hero-area {
    background: linear-gradient(135deg, #e5f7bf 0%, #edf4ff 55%, #d2e8ff 100%);
    overflow: hidden;
  }
  .blob { position: absolute; border-radius: 50%; filter: blur(80px); opacity: 0.32; pointer-events: none; }
  .blob-g { width: 480px; height: 480px; background: var(--green); top: -180px; left: -120px; animation: blobMove 9s ease-in-out infinite; }
  .blob-b { width: 380px; height: 380px; background: var(--blue); bottom: 20px; right: -80px; animation: blobMove 12s ease-in-out infinite reverse; }
  @keyframes blobMove {
    0%,100% { transform: translate(0,0); }
    33% { transform: translate(15px,-25px); }
    66% { transform: translate(-10px,15px); }
  }
</style>
