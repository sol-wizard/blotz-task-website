---
import Layout from '../layouts/Layout.astro';
import { Icon } from 'astro-icon/components';
import { featuresUi, defaultLocale } from '../i18n/features';
import type { FeaturesLang, FeaturesKey } from '../i18n/features';
import '../styles/features.css';

const locale = (Astro.currentLocale ?? defaultLocale) as FeaturesLang;
const t = (key: FeaturesKey): string =>
  (featuresUi[locale] as typeof featuresUi[typeof defaultLocale])[key] ?? featuresUi[defaultLocale][key];

const description = locale === 'zh'
  ? 'BlotzTask 的任务管理功能帮助你快速创建任务、编辑计划、追踪截止日期，用更清晰的方式管理 ADHD 日常任务。'
  : 'BlotzTask task management helps you create tasks quickly, edit plans, and track deadlines with a clearer workflow for ADHD minds.';
---

<Layout title={`${t('tm-title')} | BlotzTask`} description={description}>
  <div class="hero-area">
    <div class="fp-hero">
      <div class="blob blob-g"></div>
      <div class="blob blob-b"></div>
      <div class="fp-hero-content">
        <div class="fp-hero-icon" style="background: rgba(150,210,27,0.15);">
          <Icon name="lucide:check-square" style="color: #4a8a0a;" />
        </div>
        <h1>{t('tm-title')}</h1>
        <p>{t('tm-sub')}</p>
      </div>
    </div>
  </div>
  <svg class="hero-wave" viewBox="0 0 1440 70" fill="none" xmlns="http://www.w3.org/2000/svg" preserveAspectRatio="none">
    <path d="M0 35 C360 70 720 0 1080 35 C1260 53 1380 22 1440 35 L1440 70 L0 70 Z" fill="#ffffff"/>
  </svg>

  <section class="fp-section">
    <div class="fp-section-inner">
      <div class="fp-text">
        <span class="fp-badge">{t('tm-f1-badge')}</span>
        <h2>{t('tm-f1-title')}</h2>
        <p>{t('tm-f1-desc')}</p>
      </div>
      <div class="fp-visual">
        <div class="fp-icon-frame" style="background: linear-gradient(135deg, #c6f2d8, #9de8b8);">
          <Icon name="lucide:list-plus" style="color: #2a7a3a;" />
        </div>
      </div>
    </div>
  </section>

  <section class="fp-section fp-section-alt">
    <div class="fp-section-inner">
      <div class="fp-text">
        <span class="fp-badge">{t('tm-f2-badge')}</span>
        <h2>{t('tm-f2-title')}</h2>
        <p>{t('tm-f2-desc')}</p>
      </div>
      <div class="fp-visual">
        <video class="fp-video" src="/en-videos/deadline.MP4" autoplay muted loop playsinline></video>
      </div>
    </div>
  </section>

  <section class="fp-cta">
    <div class="fp-cta-inner">
      <h2>{t('feat-cta-title')}</h2>
      <p>{t('feat-cta-sub')}</p>
      <div class="fp-cta-btns">
        <a class="fp-cta-btn"
          href="https://apps.apple.com/au/app/blotztask-adhd-time-manager/id6752492404"
          target="_blank" rel="noopener noreferrer">
          <Icon name="simple-icons:apple" width={18} height={18} />
          App Store
        </a>
        <a class="fp-cta-btn fp-cta-btn-out"
          href="https://play.google.com/store/apps/details?id=com.blotz.blotztask&hl=en"
          target="_blank" rel="noopener noreferrer">
          <Icon name="simple-icons:googleplay" width={16} height={16} />
          Google Play
        </a>
      </div>
    </div>
  </section>
</Layout>
