---
import Layout from '../layouts/Layout.astro';
import { Icon } from 'astro-icon/components';
import { defaultLocale } from '../i18n/landing';

const locale = Astro.currentLocale ?? defaultLocale;
const zh = locale === 'zh';

// Everything a prospective teammate needs lives in this Lark guide.
const joinDocUrl = 'https://jjpwe2n1d0yq.jp.larksuite.com/wiki/XmAswkqReieHMYkIj6Nj75Y8p0g';
const c = zh
  ? {
      title: '加入我们',
      subtitle: '和我们一起，为数百万 ADHD 人群打造更从容的效率工具。',
      rolesTitle: '我们正在寻找',
      roles: ['UI/UX 设计师', '移动端工程师', '全栈工程师', '产品营销'],
      ctaTitle: '准备加入了吗？',
      ctaSub: '岗位、流程和我们的工作方式——你需要知道的一切都在这份加入指南里。',
      ctaBtn: '查看加入指南',
    }
  : {
      title: 'Join us',
      subtitle: 'Help build calmer productivity for millions of ADHD minds.',
      rolesTitle: "We're looking for",
      roles: ['UI/UX Designer', 'Mobile Engineer', 'Full-stack Engineer', 'Product Marketing'],
      ctaTitle: 'Ready to join?',
      ctaSub: 'Everything you need — roles, process, and how we work — is in our joining guide.',
      ctaBtn: 'Open the joining guide',
    };
---

<Layout title={`${c.title} – BlotzTask`}>
  <div class="hero-area">
    <div class="sub-hero">
      <h1>{c.title}</h1>
      <p>{c.subtitle}</p>
    </div>
  </div>
  <svg class="sub-wave" viewBox="0 0 1440 70" fill="none" xmlns="http://www.w3.org/2000/svg" preserveAspectRatio="none">
    <path d="M0 35 C360 70 720 0 1080 35 C1260 53 1380 22 1440 35 L1440 70 L0 70 Z" fill="#ffffff"/>
  </svg>

  <section class="join-body">
    <div class="roles-panel">
      <h2 class="join-h2">{c.rolesTitle}</h2>
      <div class="role-tags">
        {c.roles.map((r) => <span class="role-tag">{r}</span>)}
      </div>
    </div>

    <div class="join-cta">
      <h2>{c.ctaTitle}</h2>
      <p>{c.ctaSub}</p>
      <a class="join-btn" href={joinDocUrl} target="_blank" rel="noopener noreferrer">
        <Icon name="lucide:book-open" width={18} height={18} />
        {c.ctaBtn}
        <Icon name="lucide:arrow-up-right" width={16} height={16} />
      </a>
    </div>
  </section>
</Layout>

<style>
  .sub-hero { position: relative; text-align: center; padding: 7rem 1.5rem 3rem; max-width: 680px; margin: 0 auto; }
  .sub-hero h1 { font-size: clamp(2rem, 4vw, 3rem); font-weight: 900; color: var(--text); margin-bottom: 1rem; }
  .sub-hero p { font-size: 1.1rem; color: #374151; line-height: 1.75; }
  .sub-wave { margin-top: -1px; display: block; width: 100%; }

  .join-body {
    background: #fff; max-width: 680px; margin: 0 auto;
    padding: 2.75rem 1.5rem 5rem;
    display: flex; flex-direction: column; gap: 1.75rem;
  }

  .roles-panel {
    text-align: center;
    background: linear-gradient(180deg, #f8fbf1, #ffffff);
    border: 1px solid #eaf1dd; border-radius: 24px;
    padding: 2.75rem 2rem;
  }
  .join-h2 { font-size: 1.5rem; font-weight: 900; color: var(--text); margin-bottom: 1.5rem; }
  .role-tags { display: flex; flex-wrap: wrap; justify-content: center; gap: 0.7rem; }
  .role-tag {
    padding: 0.6rem 1.2rem; border-radius: 999px;
    background: var(--green-light); border: 1px solid rgba(150,210,27,0.28);
    color: #4d7d09; font-weight: 800; font-size: 0.95rem;
  }

  .join-cta {
    text-align: center; color: #fff;
    background: linear-gradient(135deg, var(--green), var(--blue));
    border-radius: 26px; padding: 3rem 2rem;
    box-shadow: 0 22px 50px -26px rgba(52,134,243,0.6);
  }
  .join-cta h2 { font-size: 1.8rem; font-weight: 900; margin-bottom: 0.6rem; }
  .join-cta p { font-size: 1.05rem; opacity: 0.95; margin-bottom: 1.75rem; max-width: 460px; margin-left: auto; margin-right: auto; line-height: 1.6; }
  .join-btn { display: inline-flex; align-items: center; gap: 0.5rem; padding: 0.9rem 1.9rem; border-radius: 14px; background: #fff; color: var(--text); font-weight: 900; font-size: 1rem; text-decoration: none; box-shadow: 0 10px 26px -8px rgba(0,0,0,0.3); transition: transform 0.2s ease; }
  .join-btn:hover { transform: translateY(-2px); }
</style>
