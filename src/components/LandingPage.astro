---
import Layout from '../layouts/Layout.astro';
import { Icon } from 'astro-icon/components';
import { ui, defaultLocale } from '../i18n/landing';
import type { Lang, TranslationKey } from '../i18n/landing';

const locale = (Astro.currentLocale ?? defaultLocale) as Lang;
const t = (key: TranslationKey): string =>
  (ui[locale] as typeof ui[typeof defaultLocale])[key] ?? ui[defaultLocale][key];
---

<Layout
  title="BlotzTask – AI-Powered ADHD Task Manager"
  description="The AI-powered way to manage ADHD tasks. Quick task generation, AI breakdown, and easy capture."
>
  <div class="hero-area">
    <!-- HERO -->
    <section class="hero">
      <div class="blob blob-g"></div>
      <div class="blob blob-b"></div>
      <div class="hero-inner">
        <div class="hero-text">
          <h1 class="hero-title">{t('hero-title')}</h1>
          <div class="hero-stars">
            <Icon name="lucide:star" class="star-icon" /><Icon name="lucide:star" class="star-icon" /><Icon name="lucide:star" class="star-icon" /><Icon name="lucide:star" class="star-icon" /><Icon name="lucide:star" class="star-icon" />
          </div>
          <p class="hero-sub">{t('hero-sub')}</p>
          <div class="hero-downloads">
            <a class="dl-btn dl-ios"
              href="https://apps.apple.com/au/app/blotztask-adhd-time-manager/id6752492404"
              target="_blank" rel="noopener noreferrer">
              <svg width="22" height="22" viewBox="0 0 24 24" fill="currentColor">
                <path d="M18.71 19.5c-.83 1.24-1.71 2.45-3.05 2.47-1.34.03-1.77-.79-3.29-.79-1.53 0-2 .77-3.27.82-1.31.05-2.3-1.32-3.14-2.53C4.25 17 2.94 12.45 4.7 9.39c.87-1.52 2.43-2.48 4.12-2.51 1.28-.02 2.5.87 3.29.87.78 0 2.26-1.07 3.8-.91.65.03 2.47.26 3.64 1.98-.09.06-2.17 1.28-2.15 3.81.03 3.02 2.65 4.03 2.68 4.04-.03.07-.42 1.44-1.38 2.83M13 3.5c.73-.83 1.94-1.46 2.94-1.5.13 1.17-.34 2.35-1.04 3.19-.69.85-1.83 1.51-2.95 1.42-.15-1.15.41-2.35 1.05-3.11z"/>
              </svg>
              <div>
                <span class="dl-small">{t('dl-ios-s')}</span>
                <span class="dl-big">App Store</span>
              </div>
            </a>
            <a class="dl-btn dl-and"
              href="https://play.google.com/store/apps/details?id=com.blotz.blotztask&hl=en"
              target="_blank" rel="noopener noreferrer">
              <svg width="22" height="22" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
                <g clip-path="url(#clip0_47_2)">
                <mask id="mask0_47_2" style="mask-type:luminance" maskUnits="userSpaceOnUse" x="0" y="0" width="24" height="24">
                <path d="M24 0H0V24H24V0Z" fill="white"/>
                </mask>
                <g mask="url(#mask0_47_2)">
                <path d="M21.3995 12.9508L16.8795 15.2108L13.6895 12.0208L16.9095 8.80078L21.3995 11.0508C22.1895 11.4408 22.1895 12.5608 21.3995 12.9508Z" stroke="white" stroke-width="1.5" stroke-miterlimit="10" stroke-linecap="round" stroke-linejoin="round"/>
                <path d="M2 9.06025V3.07026C2 2.27026 2.83 1.76024 3.55 2.11024L16.92 8.80024L13.7 12.0202L4.12 21.6003L3.54 21.8903C2.83 22.2403 2 21.7303 2 20.9303V13.5703" stroke="white" stroke-width="1.5" stroke-miterlimit="10" stroke-linecap="round" stroke-linejoin="round"/>
                <path d="M16.8891 15.2095L4.11914 21.5995L13.6991 12.0195L16.8891 15.2095Z" stroke="white" stroke-width="1.5" stroke-miterlimit="10" stroke-linecap="round" stroke-linejoin="round"/>
                <path d="M13.6998 12.0201L4.08984 2.41016" stroke="white" stroke-width="1.5" stroke-miterlimit="10" stroke-linecap="round" stroke-linejoin="round"/>
                <path d="M16.9206 15.2409L16.8906 15.2109" stroke="white" stroke-width="1.5" stroke-miterlimit="10" stroke-linecap="round" stroke-linejoin="round"/>
                </g>
                </g>
                <defs>
                <clipPath id="clip0_47_2">
                <rect width="24" height="24" fill="white"/>
                </clipPath>
                </defs>
              </svg>
              <div>
                <span class="dl-small">{t('dl-and-s')}</span>
                <span class="dl-big">Google Play</span>
              </div>
            </a>
          </div>
        </div>
        <div class="hero-phone">
          <div class="phone-wrap">
            <video id="hero-video" class="hero-video" src="/en-videos/ai-voice-video.MP4" autoplay muted loop playsinline></video>
            <div class="phone-glow"></div>
          </div>
        </div>
      </div>
      <svg class="hero-wave" viewBox="0 0 1440 70" fill="none" xmlns="http://www.w3.org/2000/svg" preserveAspectRatio="none">
        <path d="M0 35 C360 70 720 0 1080 35 C1260 53 1380 22 1440 35 L1440 70 L0 70 Z" fill="#ffffff"/>
      </svg>
    </section>
  </div>

  <!-- FEATURES -->
  <section class="features" id="features">
    <div class="sec-inner">
      <div class="sec-head">
        <h2>{t('feat-title')}</h2>
        <p>{t('feat-sub')}</p>
      </div>
      <div class="feat-fan">
        <div class="fan-card" data-video="/en-videos/ai-voice-video.MP4">
          <div class="fan-icon"><Icon name="lucide:mic" /></div>
          <div class="fan-label">{t('f1-title')}</div>
          <div class="fan-desc">{t('f1-desc')}</div>
        </div>
        <div class="fan-card" data-video="/en-videos/month-review.MP4">
          <div class="fan-icon"><Icon name="lucide:sparkles" /></div>
          <div class="fan-label">{t('f2-title')}</div>
          <div class="fan-desc">{t('f2-desc')}</div>
        </div>
        <div class="fan-card" data-video="/en-videos/gashapon-machine.MP4">
          <div class="fan-icon"><Icon name="lucide:dices" /></div>
          <div class="fan-label">{t('f3-title')}</div>
          <div class="fan-desc">{t('f3-desc')}</div>
        </div>
        <div class="fan-card" data-video="/en-videos/note.MP4">
          <div class="fan-icon"><Icon name="lucide:notebook-pen" /></div>
          <div class="fan-label">{t('f4-title')}</div>
          <div class="fan-desc">{t('f4-desc')}</div>
        </div>
        <div class="fan-card" data-video="/en-videos/deadline.MP4">
          <div class="fan-icon"><Icon name="lucide:clock" /></div>
          <div class="fan-label">{t('f5-title')}</div>
          <div class="fan-desc">{t('f5-desc')}</div>
        </div>
      </div>
    </div>
  </section>

  <!-- FEEDBACK -->
  <section class="feedback">
    <div class="feedback-inner">
      <h2>{t('feedback-title')}</h2>
      <p>{t('feedback-sub')}</p>
      <a class="feedback-btn"
        href="https://m3cetbcyp2d.usttp.larksuite.com/share/base/form/shrutCtpZYEZ0KeRokQpJ7K96rd"
        target="_blank" rel="noopener noreferrer">
        <Icon name="lucide:message-square-heart" style="width:20px;height:20px;" />
        <span>{t('feedback-btn-label')}</span>
      </a>
    </div>
  </section>

  <!-- CONTACT -->
  <section class="contact">
    <div class="contact-inner">
      <h2>{t('contact-title')}</h2>
      <p>{t('contact-sub')}</p>
      <div class="contact-links">
        <a class="contact-card contact-rednote"
          href="https://www.xiaohongshu.com/user/profile/67bc12d6000000000e01f09a"
          target="_blank" rel="noopener noreferrer">
          <Icon name="simple-icons:xiaohongshu" style="width:26px;height:26px;" />
          <div class="contact-card-label">
            <span class="contact-card-sub">{t('contact-rn-sub')}</span>
            <span class="contact-card-name">{t('contact-rn-name')}</span>
          </div>
        </a>
        <a class="contact-card contact-linkedin"
          href="https://www.linkedin.com/company/blotz-app/"
          target="_blank" rel="noopener noreferrer">
          <Icon name="lucide:linkedin" style="width:26px;height:26px;" />
          <div class="contact-card-label">
            <span class="contact-card-sub">{t('contact-li-sub')}</span>
            <span class="contact-card-name">{t('contact-li-name')}</span>
          </div>
        </a>
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="cta">
    <div class="cta-inner">
      <h2>{t('cta-title')}</h2>
      <p>{t('cta-sub')}</p>
      <div class="cta-btns">
        <a class="cta-btn"
          href="https://apps.apple.com/au/app/blotztask-adhd-time-manager/id6752492404"
          target="_blank" rel="noopener noreferrer">
          <svg width="22" height="22" viewBox="0 0 24 24" fill="currentColor">
            <path d="M18.71 19.5c-.83 1.24-1.71 2.45-3.05 2.47-1.34.03-1.77-.79-3.29-.79-1.53 0-2 .77-3.27.82-1.31.05-2.3-1.32-3.14-2.53C4.25 17 2.94 12.45 4.7 9.39c.87-1.52 2.43-2.48 4.12-2.51 1.28-.02 2.5.87 3.29.87.78 0 2.26-1.07 3.8-.91.65.03 2.47.26 3.64 1.98-.09.06-2.17 1.28-2.15 3.81.03 3.02 2.65 4.03 2.68 4.04-.03.07-.42 1.44-1.38 2.83M13 3.5c.73-.83 1.94-1.46 2.94-1.5.13 1.17-.34 2.35-1.04 3.19-.69.85-1.83 1.51-2.95 1.42-.15-1.15.41-2.35 1.05-3.11z"/>
          </svg>
          App Store
        </a>
        <a class="cta-btn cta-btn-out"
          href="https://play.google.com/store/apps/details?id=com.blotz.blotztask&hl=en"
          target="_blank" rel="noopener noreferrer">
          <svg width="20" height="20" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg"><g clip-path="url(#ctaclip)"><mask id="ctamask" style="mask-type:luminance" maskUnits="userSpaceOnUse" x="0" y="0" width="24" height="24"><path d="M24 0H0V24H24V0Z" fill="white"/></mask><g mask="url(#ctamask)"><path d="M21.3995 12.9508L16.8795 15.2108L13.6895 12.0208L16.9095 8.80078L21.3995 11.0508C22.1895 11.4408 22.1895 12.5608 21.3995 12.9508Z" stroke="currentColor" stroke-width="1.5" stroke-miterlimit="10" stroke-linecap="round" stroke-linejoin="round"/><path d="M2 9.06025V3.07026C2 2.27026 2.83 1.76024 3.55 2.11024L16.92 8.80024L13.7 12.0202L4.12 21.6003L3.54 21.8903C2.83 22.2403 2 21.7303 2 20.9303V13.5703" stroke="currentColor" stroke-width="1.5" stroke-miterlimit="10" stroke-linecap="round" stroke-linejoin="round"/><path d="M16.8891 15.2095L4.11914 21.5995L13.6991 12.0195L16.8891 15.2095Z" stroke="currentColor" stroke-width="1.5" stroke-miterlimit="10" stroke-linecap="round" stroke-linejoin="round"/><path d="M13.6998 12.0201L4.08984 2.41016" stroke="currentColor" stroke-width="1.5" stroke-miterlimit="10" stroke-linecap="round" stroke-linejoin="round"/></g></g><defs><clipPath id="ctaclip"><rect width="24" height="24" fill="white"/></clipPath></defs></svg>
          Google Play
        </a>
      </div>
    </div>
  </section>

  <!-- FOOTER -->
  <footer class="footer">
    <p>{t('footer-copy')}</p>
  </footer>

  <script>
    const fanCards = Array.from(document.querySelectorAll('.fan-card')) as HTMLElement[];
    const lightbox = document.getElementById('lightbox')!;
    const lbVideo = document.getElementById('lightbox-video') as HTMLVideoElement;
    const lbClose = document.getElementById('lightbox-close')!;
    const lbPrev = document.getElementById('lightbox-prev')!;
    const lbNext = document.getElementById('lightbox-next')!;
    const lbTitle = document.getElementById('lightbox-title')!;
    const lbDesc = document.getElementById('lightbox-desc')!;
    let currentIndex = 0;

    function loadCard(index: number) {
      const card = fanCards[index];
      lbVideo.src = card.dataset.video!;
      lbTitle.textContent = card.querySelector('.fan-label')?.textContent ?? '';
      lbDesc.textContent = card.querySelector('.fan-desc')?.textContent ?? '';
      lbVideo.load();
      lbVideo.play();
    }
    function openLightbox(index: number) {
      currentIndex = index;
      loadCard(index);
      lightbox.classList.add('open');
      document.body.style.overflow = 'hidden';
    }
    function closeLightbox() {
      lightbox.classList.remove('open');
      lbVideo.pause();
      lbVideo.src = '';
      document.body.style.overflow = '';
    }
    function navigate(dir: number) {
      currentIndex = (currentIndex + dir + fanCards.length) % fanCards.length;
      loadCard(currentIndex);
    }

    fanCards[2]?.classList.add('active');
    fanCards.forEach((card, i) => {
      card.addEventListener('click', () => {
        fanCards.forEach(c => c.classList.remove('active'));
        card.classList.add('active');
        openLightbox(i);
      });
    });
    lbClose.addEventListener('click', closeLightbox);
    lbPrev.addEventListener('click', () => navigate(-1));
    lbNext.addEventListener('click', () => navigate(1));
    lightbox.querySelector('.lightbox-backdrop')!.addEventListener('click', closeLightbox);
    document.addEventListener('keydown', (e) => {
      if (!lightbox.classList.contains('open')) return;
      if (e.key === 'Escape') closeLightbox();
      if (e.key === 'ArrowLeft') navigate(-1);
      if (e.key === 'ArrowRight') navigate(1);
    });

    const heroVideo = document.getElementById('hero-video') as HTMLVideoElement;
    if (heroVideo) {
      heroVideo.playbackRate = 3;
      heroVideo.addEventListener('loadedmetadata', () => { heroVideo.playbackRate = 3; });
    }
  </script>

  <!-- VIDEO LIGHTBOX -->
  <div id="lightbox" class="lightbox" aria-modal="true" role="dialog">
    <div class="lightbox-backdrop"></div>
    <button class="lightbox-close" id="lightbox-close" aria-label="Close">
      <svg width="26" height="26" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round">
        <line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/>
      </svg>
    </button>
    <div class="lightbox-content">
      <h2 class="lightbox-title" id="lightbox-title"></h2>
      <div class="lightbox-body">
        <button class="lightbox-arrow" id="lightbox-prev" aria-label="Previous">
          <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="15 18 9 12 15 6"/></svg>
        </button>
        <video id="lightbox-video" class="lightbox-video" playsinline controls></video>
        <div class="lightbox-info">
          <p class="lightbox-desc" id="lightbox-desc"></p>
        </div>
        <button class="lightbox-arrow" id="lightbox-next" aria-label="Next">
          <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="9 18 15 12 9 6"/></svg>
        </button>
      </div>
    </div>
  </div>
</Layout>

<style is:global>
  .hero-area {
    background: linear-gradient(135deg, #e5f7bf 0%, #edf4ff 55%, #d2e8ff 100%);
    overflow: hidden;
  }
  .hero { position: relative; background: transparent; }
  .blob { position: absolute; border-radius: 50%; filter: blur(80px); opacity: 0.32; pointer-events: none; }
  .blob-g { width: 480px; height: 480px; background: var(--green); top: -180px; left: -120px; animation: blobMove 9s ease-in-out infinite; }
  .blob-b { width: 380px; height: 380px; background: var(--blue); bottom: 20px; right: -80px; animation: blobMove 12s ease-in-out infinite reverse; }
  @keyframes blobMove {
    0%,100% { transform: translate(0,0); }
    33% { transform: translate(15px,-25px); }
    66% { transform: translate(-10px,15px); }
  }
  .hero-inner {
    position: relative; z-index: 1;
    max-width: 1100px; margin: 0 auto;
    padding: 7rem 1.5rem 3.5rem;
    display: grid; grid-template-columns: 1fr 480px; align-items: center; gap: 3rem;
  }
  .hero-title { font-size: clamp(2rem, 3.5vw, 3.1rem); font-weight: 900; line-height: 1.2; color: var(--text); margin-bottom: 1rem; }
  @keyframes star-pop {
    0%   { transform: scale(0.4); opacity: 0; fill: transparent; color: #f59e0b; }
    60%  { transform: scale(1.3); opacity: 1; fill: #fbbf24; color: #fbbf24; }
    100% { transform: scale(1);   opacity: 1; fill: #f59e0b; color: #f59e0b; }
  }
  .hero-stars { display: flex; gap: 0.2rem; margin-bottom: 0.5rem; }
  .hero-stars .star-icon { width: 20px; height: 20px; color: #f59e0b; opacity: 0; animation: star-pop 0.4s cubic-bezier(0.34, 1.56, 0.64, 1) forwards; }
  .hero-stars .star-icon path { fill: #f59e0b; stroke: #f59e0b; }
  .hero-stars .star-icon:nth-child(1) { animation-delay: 0.1s; }
  .hero-stars .star-icon:nth-child(2) { animation-delay: 0.22s; }
  .hero-stars .star-icon:nth-child(3) { animation-delay: 0.34s; }
  .hero-stars .star-icon:nth-child(4) { animation-delay: 0.46s; }
  .hero-stars .star-icon:nth-child(5) { animation-delay: 0.58s; }
  .hero-sub { font-size: 1.05rem; color: #374151; margin-bottom: 2rem; line-height: 1.75; }
  .hero-downloads { display: flex; flex-wrap: wrap; gap: 0.75rem; }
  .dl-btn { display: flex; align-items: center; gap: 0.75rem; padding: 0.8rem 1.5rem; border-radius: 14px; text-decoration: none; transition: transform 0.2s, box-shadow 0.2s; }
  .dl-btn:hover { transform: translateY(-2px); box-shadow: var(--shadow-lg); }
  .dl-btn > div { display: flex; flex-direction: column; }
  .dl-small { font-size: 0.68rem; font-weight: 600; opacity: 0.8; line-height: 1; }
  .dl-big { font-size: 1rem; font-weight: 800; line-height: 1.3; }
  .dl-ios { background: #1a1a2e; color: white; }
  .dl-and { background: var(--green); color: white; }
  .hero-phone { display: flex; justify-content: center; }
  .phone-wrap { position: relative; animation: float 4s ease-in-out infinite; }
  @keyframes float { 0%,100% { transform: translateY(0); } 50% { transform: translateY(-12px); } }
  .hero-video { width: 260px; border-radius: 38px; box-shadow: 0 30px 80px rgba(52,134,243,0.25), 0 0 0 1px rgba(255,255,255,0.08); display: block; position: relative; z-index: 1; }
  .phone-glow { position: absolute; width: 180px; height: 180px; background: radial-gradient(circle, rgba(150,210,27,0.4), transparent 70%); bottom: -55px; left: 50%; transform: translateX(-50%); border-radius: 50%; filter: blur(20px); z-index: 0; }
  .hero-wave { margin-top: -1px; display: block; width: 100%; }

  .features { padding: 4rem 0 5rem; overflow: hidden; background: white; }
  .sec-inner { max-width: 1100px; margin: 0 auto; }
  .sec-head { text-align: center; margin-bottom: 0; padding: 0 1.5rem 0.5rem; }
  .sec-head h2 { font-size: 2.2rem; font-weight: 900; color: var(--text); margin-bottom: 0.5rem; }
  .sec-head p { font-size: 1.05rem; color: var(--muted); }
  .feat-fan { display: flex; justify-content: center; align-items: flex-end; padding: 3.5rem 2rem 5rem; }
  .fan-card { width: 210px; min-height: 290px; border-radius: 26px; padding: 1.6rem 1.4rem 1.5rem; flex-shrink: 0; margin: 0 -20px; position: relative; box-shadow: 0 8px 28px rgba(0,0,0,0.10); cursor: pointer; transition: transform 0.4s cubic-bezier(0.34, 1.56, 0.64, 1), box-shadow 0.35s ease; display: flex; flex-direction: column; gap: 0.5rem; user-select: none; }
  .fan-card:nth-child(1) { transform: rotate(-15deg) translateY(38px); z-index: 1; background: linear-gradient(155deg, #e2f7b2, #cff086); }
  .fan-card:nth-child(2) { transform: rotate(-7deg) translateY(18px); z-index: 2; background: linear-gradient(155deg, #d5e9ff, #b8d8ff); }
  .fan-card:nth-child(3) { transform: rotate(0deg) translateY(0); z-index: 5; background: linear-gradient(155deg, #ede0ff, #d5bdff); }
  .fan-card:nth-child(4) { transform: rotate(7deg) translateY(18px); z-index: 2; background: linear-gradient(155deg, #ffd9ef, #ffbfe4); }
  .fan-card:nth-child(5) { transform: rotate(15deg) translateY(38px); z-index: 1; background: linear-gradient(155deg, #fff0c0, #ffe48a); }
  .fan-card.active { transform: rotate(0deg) translateY(-18px) scale(1.06) !important; z-index: 10 !important; box-shadow: 0 24px 60px rgba(0,0,0,0.18) !important; }
  .fan-card:not(.active):hover { transform: rotate(0deg) translateY(-8px) !important; z-index: 8 !important; box-shadow: 0 14px 40px rgba(0,0,0,0.14) !important; }
  .fan-icon { flex-shrink: 0; }
  .fan-icon svg { width: 2.4rem; height: 2.4rem; stroke-width: 1.5; color: var(--text); }
  .fan-label { font-size: 1rem; font-weight: 800; color: var(--text); margin-top: auto; padding-top: 0.5rem; }
  .fan-desc { font-size: 0.8rem; color: #374151; line-height: 1.6; }

  .cta { background: linear-gradient(135deg, var(--green) 0%, var(--blue) 100%); padding: 5rem 1.5rem; text-align: center; color: white; position: relative; overflow: hidden; }
  .cta::before, .cta::after { content: ''; position: absolute; border-radius: 50%; background: rgba(255,255,255,0.08); }
  .cta::before { width: 400px; height: 400px; top: -160px; left: -100px; }
  .cta::after { width: 280px; height: 280px; bottom: -100px; right: -60px; }
  .cta-inner { position: relative; z-index: 1; max-width: 600px; margin: 0 auto; }
  .cta h2 { font-size: 2.4rem; font-weight: 900; margin-bottom: 0.75rem; }
