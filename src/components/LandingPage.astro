---
import Layout from '../layouts/Layout.astro';
import { Icon } from 'astro-icon/components';
import { ui, defaultLocale } from '../i18n/landing';
import type { Lang, TranslationKey } from '../i18n/landing';

const locale = (Astro.currentLocale ?? defaultLocale) as Lang;
const t = (key: TranslationKey): string =>
  (ui[locale] as typeof ui[typeof defaultLocale])[key] ?? ui[defaultLocale][key];

const features = [
  {
    icon: 'lucide:mic',
    title: t('f1-title'),
    desc: t('f1-desc'),
    video: '/en-videos/ai-voice-video.MP4',
    poster: '/en-pic/ai-voice.PNG',
  },
  {
    icon: 'lucide:sparkles',
    title: t('f2-title'),
    desc: t('f2-desc'),
    video: '/en-videos/month-review.MP4',
    poster: '/en-pic/monthly-review.PNG',
  },
  {
    icon: 'lucide:dices',
    title: t('f3-title'),
    desc: t('f3-desc'),
    video: '/en-videos/gashapon-machine.MP4',
    poster: '/shared-pic/gashapon.PNG',
  },
  {
    icon: 'lucide:notebook-pen',
    title: t('f4-title'),
    desc: t('f4-desc'),
    video: '/en-videos/note.MP4',
    poster: undefined,
  },
  {
    icon: 'lucide:clock',
    title: t('f5-title'),
    desc: t('f5-desc'),
    video: '/en-videos/deadline.MP4',
    poster: '/en-pic/calendar.PNG',
  },
];
---

<Layout
  title="BlotzTask – AI-Powered ADHD Task Manager"
  description="The AI-powered way to manage ADHD tasks. Quick task generation, AI breakdown, and easy capture."
>
  <div class="hero-area">
    <!-- HERO -->
    <section class="hero">
      <div class="blob blob-g"></div>
      <div class="blob blob-b"></div>
      <div class="hero-inner">
        <div class="hero-text">
          <div class="hero-eyebrow">
            <span class="hero-stars" aria-hidden="true">★★★★★</span>
            <span>{t('hero-eyebrow')}</span>
          </div>
          <h1 class="hero-title">{t('hero-title')}</h1>
          <p class="hero-sub">{t('hero-sub')}</p>
          <a class="hero-cta" href="#download">
            <span>{t('hero-download-cta')}</span>
            <Icon name="lucide:arrow-right" />
          </a>
        </div>
        <div class="hero-phone">
          <div class="phone-wrap">
            <video id="hero-video" class="hero-video" src="/en-videos/ai-voice-video.MP4" autoplay muted loop playsinline></video>
            <div class="phone-glow"></div>
          </div>
        </div>
      </div>
      <svg class="hero-wave" viewBox="0 0 1440 70" fill="none" xmlns="http://www.w3.org/2000/svg" preserveAspectRatio="none">
        <path d="M0 35 C360 70 720 0 1080 35 C1260 53 1380 22 1440 35 L1440 70 L0 70 Z" fill="#ffffff"/>
      </svg>
    </section>
  </div>

  <!-- FEATURES -->
  <section class="features" id="features">
    <div class="sec-inner">
      <div class="feature-demo" data-feature-demo>
        <div class="feature-preview">
          <div class="feature-preview-sticky">
            <div class="feature-phone" aria-hidden="true">
              <video
                id="feature-preview-video"
                class="feature-preview-video"
                src={features[0].video}
                poster={features[0].poster}
                autoplay
                muted
                loop
                playsinline
              ></video>
              <div class="feature-phone-glow"></div>
            </div>
          </div>
        </div>

        <div class="feature-list" aria-label={t('feat-title')}>
          <div class="feature-progress" aria-hidden="true">
            <span class="feature-progress-fill"></span>
          </div>
          {features.map((feature, index) => (
            <button
              class:list={['feature-card', { active: index === 0 }]}
              type="button"
              data-feature-card
              data-feature-index={index}
              data-video={feature.video}
              data-poster={feature.poster}
            >
              <span class="feature-number">{String(index + 1).padStart(2, '0')}</span>
              <span class="feature-card-icon"><Icon name={feature.icon} /></span>
              <span class="feature-card-text">
                <span class="feature-card-title">{feature.title}</span>
                <span class="feature-card-desc">{feature.desc}</span>
              </span>
              <span class="feature-card-cue" aria-hidden="true"><Icon name="lucide:arrow-up-right" /></span>
              <span class:list={['feature-card-media', { 'has-fallback': !feature.poster }]} aria-hidden="true">
                <video
                  class="mobile-feature-video"
                  src={feature.video}
                  poster={feature.poster}
                  muted
                  loop
                  playsinline
                  preload="metadata"
                ></video>
                {!feature.poster && (
                  <span class="feature-media-fallback">
                    <Icon name={feature.icon} />
                    <span>{feature.title}</span>
                  </span>
                )}
              </span>
            </button>
          ))}
        </div>
      </div>
    </div>
  </section>

  <!-- FAQ -->
  <section class="faq">
    <div class="faq-inner">
      <h2>{t('faq-title')}</h2>
      <div class="faq-list">
        {([1,2,3,4,5] as const).map((n) => (
          <details class="faq-item">
            <summary class="faq-question">
              <span>{t(`faq-q${n}` as TranslationKey)}</span>
              <svg class="faq-chevron" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="6 9 12 15 18 9"/></svg>
            </summary>
            <div class="faq-answer">
              <p>{t(`faq-a${n}` as TranslationKey)}</p>
            </div>
          </details>
        ))}
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="cta" id="download">
    <div class="cta-inner">
      <h2>{t('cta-title')}</h2>
      <p>{t('cta-sub')}</p>
      <div class="cta-btns">
        <a class="cta-btn"
          href="https://apps.apple.com/au/app/blotztask-adhd-time-manager/id6752492404"
          target="_blank" rel="noopener noreferrer">
          <svg width="22" height="22" viewBox="0 0 24 24" fill="currentColor">
            <path d="M18.71 19.5c-.83 1.24-1.71 2.45-3.05 2.47-1.34.03-1.77-.79-3.29-.79-1.53 0-2 .77-3.27.82-1.31.05-2.3-1.32-3.14-2.53C4.25 17 2.94 12.45 4.7 9.39c.87-1.52 2.43-2.48 4.12-2.51 1.28-.02 2.5.87 3.29.87.78 0 2.26-1.07 3.8-.91.65.03 2.47.26 3.64 1.98-.09.06-2.17 1.28-2.15 3.81.03 3.02 2.65 4.03 2.68 4.04-.03.07-.42 1.44-1.38 2.83M13 3.5c.73-.83 1.94-1.46 2.94-1.5.13 1.17-.34 2.35-1.04 3.19-.69.85-1.83 1.51-2.95 1.42-.15-1.15.41-2.35 1.05-3.11z"/>
          </svg>
          App Store
        </a>
        <a class="cta-btn cta-btn-out"
          href="https://play.google.com/store/apps/details?id=com.blotz.blotztask&hl=en"
          target="_blank" rel="noopener noreferrer">
          <svg width="20" height="20" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg"><g clip-path="url(#ctaclip)"><mask id="ctamask" style="mask-type:luminance" maskUnits="userSpaceOnUse" x="0" y="0" width="24" height="24"><path d="M24 0H0V24H24V0Z" fill="white"/></mask><g mask="url(#ctamask)"><path d="M21.3995 12.9508L16.8795 15.2108L13.6895 12.0208L16.9095 8.80078L21.3995 11.0508C22.1895 11.4408 22.1895 12.5608 21.3995 12.9508Z" stroke="currentColor" stroke-width="1.5" stroke-miterlimit="10" stroke-linecap="round" stroke-linejoin="round"/><path d="M2 9.06025V3.07026C2 2.27026 2.83 1.76024 3.55 2.11024L16.92 8.80024L13.7 12.0202L4.12 21.6003L3.54 21.8903C2.83 22.2403 2 21.7303 2 20.9303V13.5703" stroke="currentColor" stroke-width="1.5" stroke-miterlimit="10" stroke-linecap="round" stroke-linejoin="round"/><path d="M16.8891 15.2095L4.11914 21.5995L13.6991 12.0195L16.8891 15.2095Z" stroke="currentColor" stroke-width="1.5" stroke-miterlimit="10" stroke-linecap="round" stroke-linejoin="round"/><path d="M13.6998 12.0201L4.08984 2.41016" stroke="currentColor" stroke-width="1.5" stroke-miterlimit="10" stroke-linecap="round" stroke-linejoin="round"/></g></g><defs><clipPath id="ctaclip"><rect width="24" height="24" fill="white"/></clipPath></defs></svg>
          Google Play
        </a>
      </div>
    </div>
  </section>

  <script>
    const featureCards = Array.from(document.querySelectorAll('[data-feature-card]')) as HTMLElement[];
    const featureList = document.querySelector('.feature-list') as HTMLElement | null;
    const previewVideo = document.getElementById('feature-preview-video') as HTMLVideoElement | null;
    const lightbox = document.getElementById('lightbox')!;
    const lbVideo = document.getElementById('lightbox-video') as HTMLVideoElement;
    const lbClose = document.getElementById('lightbox-close')!;
    const lbPrev = document.getElementById('lightbox-prev')!;
    const lbNext = document.getElementById('lightbox-next')!;
    const lbTitle = document.getElementById('lightbox-title')!;
    const lbDesc = document.getElementById('lightbox-desc')!;
    let currentIndex = 0;
    let activeIndex = 0;
    const reduceMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;

    function loadCard(index: number) {
      const card = featureCards[index];
      lbVideo.src = card.dataset.video!;
      lbVideo.poster = card.dataset.poster ?? '';
      lbTitle.textContent = card.querySelector('.feature-card-title')?.textContent ?? '';
      lbDesc.textContent = card.querySelector('.feature-card-desc')?.textContent ?? '';
      lbVideo.load();
      lbVideo.play().catch(() => {});
    }
    function openLightbox(index: number) {
      currentIndex = index;
      loadCard(index);
      lightbox.classList.add('open');
      document.body.style.overflow = 'hidden';
    }
    function closeLightbox() {
      lightbox.classList.remove('open');
      lbVideo.pause();
      lbVideo.src = '';
      lbVideo.poster = '';
      document.body.style.overflow = '';
    }
    function navigate(dir: number) {
      currentIndex = (currentIndex + dir + featureCards.length) % featureCards.length;
      loadCard(currentIndex);
      setActiveFeature(currentIndex, false);
    }

    function updatePreviewVideo(videoSrc: string) {
      if (!previewVideo || previewVideo.src.endsWith(videoSrc)) return;

      const swapVideo = () => {
        previewVideo.src = videoSrc;
        const activeCard = featureCards[activeIndex];
        previewVideo.poster = activeCard?.dataset.poster ?? '';
        previewVideo.load();
        previewVideo.play().catch(() => {});
        previewVideo.classList.remove('switching');
      };

      if (reduceMotion) {
        swapVideo();
        return;
      }

      previewVideo.classList.add('switching');
      window.setTimeout(swapVideo, 140);
    }

    function setActiveFeature(index: number, updateVideo = true) {
      const card = featureCards[index];
      if (!card) return;

      activeIndex = index;
      featureCards.forEach((item, itemIndex) => {
        item.classList.toggle('active', itemIndex === index);
        item.setAttribute('aria-pressed', String(itemIndex === index));
      });
      featureList?.style.setProperty('--feature-progress', String((index + 1) / featureCards.length));
      if (updateVideo) updatePreviewVideo(card.dataset.video!);
    }

    featureCards.forEach((card, i) => {
      card.setAttribute('aria-pressed', String(i === 0));
      card.addEventListener('focus', () => setActiveFeature(i));
      card.addEventListener('click', () => {
        setActiveFeature(i);
        openLightbox(i);
      });
    });

    if ('IntersectionObserver' in window && featureCards.length) {
      const observer = new IntersectionObserver((entries) => {
        const centered = entries
          .filter((entry) => entry.isIntersecting)
          .sort((a, b) => b.intersectionRatio - a.intersectionRatio)[0];
        const index = centered?.target instanceof HTMLElement
          ? Number(centered.target.dataset.featureIndex)
          : NaN;
        if (Number.isFinite(index) && index !== activeIndex) setActiveFeature(index);
      }, {
        threshold: 0,
        rootMargin: '-46% 0px -46% 0px',
      });

      featureCards.forEach((card) => observer.observe(card));
    }

    const mobileVideos = Array.from(document.querySelectorAll('.mobile-feature-video')) as HTMLVideoElement[];
    if ('IntersectionObserver' in window && mobileVideos.length) {
      const videoObserver = new IntersectionObserver((entries) => {
        entries.forEach((entry) => {
          const video = entry.target as HTMLVideoElement;
          if (entry.isIntersecting) {
            video.play().catch(() => {});
          } else {
            video.pause();
          }
        });
      }, { threshold: 0.45 });

      mobileVideos.forEach((video) => videoObserver.observe(video));
    }

    lbClose.addEventListener('click', closeLightbox);
    lbPrev.addEventListener('click', () => navigate(-1));
    lbNext.addEventListener('click', () => navigate(1));
    lightbox.querySelector('.lightbox-backdrop')!.addEventListener('click', closeLightbox);
    document.addEventListener('keydown', (e) => {
      if (!lightbox.classList.contains('open')) return;
      if (e.key === 'Escape') closeLightbox();
      if (e.key === 'ArrowLeft') navigate(-1);
      if (e.key === 'ArrowRight') navigate(1);
    });
    setActiveFeature(0, false);

    const heroVideo = document.getElementById('hero-video') as HTMLVideoElement;
    if (heroVideo) {
      heroVideo.playbackRate = 3;
      heroVideo.addEventListener('loadedmetadata', () => { heroVideo.playbackRate = 3; });
    }
  </script>

  <!-- VIDEO LIGHTBOX -->
  <div id="lightbox" class="lightbox" aria-modal="true" role="dialog">
    <div class="lightbox-backdrop"></div>
    <button class="lightbox-close" id="lightbox-close" aria-label="Close">
      <svg width="26" height="26" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round">
        <line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/>
      </svg>
    </button>
    <div class="lightbox-content">
      <h2 class="lightbox-title" id="lightbox-title"></h2>
      <div class="lightbox-body">
        <button class="lightbox-arrow" id="lightbox-prev" aria-label="Previous">
          <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="15 18 9 12 15 6"/></svg>
        </button>
        <video id="lightbox-video" class="lightbox-video" playsinline controls></video>
        <div class="lightbox-info">
          <p class="lightbox-desc" id="lightbox-desc"></p>
        </div>
        <button class="lightbox-arrow" id="lightbox-next" aria-label="Next">
          <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="9 18 15 12 9 6"/></svg>
        </button>
      </div>
    </div>
  </div>
</Layout>

<style is:global>
  .hero { position: relative; background: transparent; }
  .hero-inner {
    position: relative; z-index: 1;
    max-width: 1260px; margin: 0 auto;
    padding: 7rem 2rem 3.5rem;
    display: grid; grid-template-columns: minmax(0, 1fr) 520px; align-items: center; gap: 3.5rem;
  }
  .hero-eyebrow { display: inline-flex; align-items: center; gap: 0.5rem; margin-bottom: 1.1rem; padding: 0.35rem 0.85rem; border-radius: 999px; background: rgba(255,255,255,0.65); border: 1px solid rgba(150,210,27,0.35); font-size: 0.82rem; font-weight: 800; color: var(--text); box-shadow: 0 4px 14px rgba(30,33,64,0.06); backdrop-filter: blur(6px); }
  .hero-stars { color: #f5a623; letter-spacing: 1px; font-size: 0.8rem; }
  .hero-title { font-size: clamp(2rem, 3.35vw, 3rem); font-weight: 900; line-height: 1.22; color: var(--text); margin-bottom: 1rem; }
  .hero-sub { font-size: 1.05rem; color: #374151; margin-bottom: 2rem; line-height: 1.7; max-width: 30rem; }
  .hero-cta { display: inline-flex; align-items: center; gap: 0.6rem; padding: 1rem 1.9rem; border-radius: 16px; background: linear-gradient(135deg, var(--green), var(--blue)); color: white; font-family: 'Nunito', 'PingFang SC', sans-serif; font-weight: 900; font-size: 1.05rem; text-decoration: none; box-shadow: 0 12px 30px -8px rgba(52,134,243,0.55); transition: transform 0.2s ease, box-shadow 0.2s ease; animation: cta-pulse 2.8s ease-in-out infinite; }
  .hero-cta:hover { transform: translateY(-2px) scale(1.02); box-shadow: 0 18px 40px -8px rgba(52,134,243,0.7); animation-play-state: paused; }
  .hero-cta svg { width: 20px; height: 20px; flex-shrink: 0; transition: transform 0.2s ease; }
  .hero-cta:hover svg { transform: translateX(3px); }
  @keyframes cta-pulse { 0%, 100% { box-shadow: 0 12px 30px -8px rgba(52,134,243,0.5); } 50% { box-shadow: 0 12px 38px -6px rgba(52,134,243,0.85); } }
  @media (prefers-reduced-motion: reduce) { .hero-cta { animation: none; } }
  .hero-phone { display: flex; justify-content: flex-end; }
  .phone-wrap { position: relative; animation: float 4s ease-in-out infinite; }
  @keyframes float { 0%,100% { transform: translateY(0); } 50% { transform: translateY(-12px); } }
  .hero-video { width: 280px; border-radius: 40px; box-shadow: 0 30px 80px rgba(52,134,243,0.25), 0 0 0 1px rgba(255,255,255,0.08); display: block; position: relative; z-index: 1; }
  .phone-glow { position: absolute; width: 180px; height: 180px; background: radial-gradient(circle, rgba(150,210,27,0.4), transparent 70%); bottom: -55px; left: 50%; transform: translateX(-50%); border-radius: 50%; filter: blur(20px); z-index: 0; }
  .hero-wave { margin-top: -1px; display: block; width: 100%; }

  .features { scroll-margin-top: 6rem; padding: 2.5rem 0 5.5rem; overflow: clip; background: white; }
  .sec-inner { max-width: 1260px; margin: 0 auto; }
  .feature-demo {
    --feature-step-height: clamp(430px, 56vh, 540px);
    display: grid;
    grid-template-columns: minmax(360px, 0.98fr) minmax(0, 1.02fr);
    align-items: start;
    gap: 3.5rem;
    padding: 0 2rem;
  }
  .feature-preview { min-height: 2820px; }
  .feature-preview-sticky {
    position: sticky;
    top: 7rem;
    display: grid;
    align-content: center;
    justify-items: center;
    min-height: calc(100vh - 9rem);
    padding: clamp(0.25rem, 1vw, 0.75rem);
  }
  .feature-phone {
    position: relative;
    display: grid;
    place-items: center;
    width: min(500px, 96%);
    margin: 0 auto;
  }
  .feature-preview-video {
    position: relative;
    z-index: 1;
    width: auto;
    max-width: 100%;
    max-height: calc(100vh - 9.5rem);
    border-radius: clamp(34px, 6vw, 48px);
    box-shadow:
      0 32px 82px rgba(52,134,243,0.22),
      0 0 0 1px rgba(30,33,64,0.08);
    transition: opacity 0.22s ease, transform 0.22s ease;
  }
  .feature-preview-video.switching {
    opacity: 0;
    transform: translateY(8px) scale(0.985);
  }
  .feature-phone-glow {
    position: absolute;
    inset: auto -18% -2.4rem;
    height: 58%;
    border-radius: 999px;
    background: linear-gradient(135deg, rgba(150,210,27,0.36), rgba(52,134,243,0.38));
    filter: blur(40px);
  }
  .feature-list {
    --feature-progress: 0.2;
    position: relative;
    display: grid;
    gap: 1.75rem;
    padding-left: 1.35rem;
  }
  .feature-progress {
    position: absolute;
    top: 1.1rem;
    bottom: 1.1rem;
    left: 0;
    width: 3px;
    overflow: hidden;
    border-radius: 999px;
    background: #e7edf5;
  }
  .feature-progress-fill {
    display: block;
    width: 100%;
    height: 100%;
    border-radius: inherit;
    background: linear-gradient(180deg, var(--green), var(--blue));
    transform: scaleY(var(--feature-progress));
    transform-origin: top;
    transition: transform 0.28s ease;
  }
  .feature-card {
    position: relative;
    display: grid;
    grid-template-columns: 2.4rem 3rem minmax(0, 1fr) 2rem;
    align-items: center;
    gap: 1rem;
    min-height: var(--feature-step-height);
    width: 100%;
    padding: 1.45rem 1.35rem;
    border: 1px solid rgba(30,33,64,0.08);
    border-radius: 18px;
    background: #fff;
    box-shadow: 0 8px 28px rgba(30,33,64,0.055);
    color: var(--text);
    text-align: left;
    cursor: pointer;
    font-family: 'Nunito', 'PingFang SC', 'Microsoft YaHei', system-ui, sans-serif;
    transition: border-color 0.2s ease, box-shadow 0.2s ease, background 0.2s ease, transform 0.2s ease;
  }
  .feature-card:hover {
    transform: translateY(-2px);
    border-color: rgba(52,134,243,0.2);
    box-shadow: 0 16px 42px rgba(30,33,64,0.1);
  }
  .feature-card:focus { outline: none; }
  .feature-card:focus-visible { outline: 2px solid var(--blue); outline-offset: 4px; }
  .feature-card.active {
    border-color: rgba(150,210,27,0.44);
    background: linear-gradient(135deg, #fbfff2, #f4faff);
    box-shadow: 0 20px 50px rgba(52,134,243,0.12);
  }
  .feature-number {
    color: #8ba0b8;
    font-size: 0.84rem;
    font-weight: 900;
  }
  .feature-card.active .feature-number { color: #4d7d09; }
  .feature-card-icon {
    display: grid;
    place-items: center;
    width: 3rem;
    height: 3rem;
    border-radius: 14px;
    color: var(--green);
    background: var(--green-light);
  }
  .feature-card-icon svg { width: 1.5rem; height: 1.5rem; stroke-width: 1.8; }
  .feature-card-text { min-width: 0; }
  .feature-card-title {
    display: block;
    color: var(--text);
    font-size: 1.14rem;
    font-weight: 900;
    line-height: 1.25;
    overflow-wrap: break-word;
  }
  .feature-card-desc {
    display: block;
    margin-top: 0.45rem;
    color: #4b5563;
    font-size: 0.96rem;
    line-height: 1.62;
    overflow-wrap: break-word;
  }
  .feature-card-cue {
    display: grid;
    place-items: center;
    width: 2rem;
    height: 2rem;
    color: #7b8aa0;
    border-radius: 10px;
    background: #f4f7fb;
  }
  .feature-card-cue svg { width: 1rem; height: 1rem; }
  .feature-card-media { display: none; }

  .cta { background: linear-gradient(135deg, var(--green) 0%, var(--blue) 100%); padding: 5rem 1.5rem; text-align: center; color: white; position: relative; overflow: hidden; }
  .cta::before, .cta::after { content: ''; position: absolute; border-radius: 50%; background: rgba(255,255,255,0.08); }
