---
import Layout from '../layouts/Layout.astro';
import { Icon } from 'astro-icon/components';
import { ui, defaultLocale } from '../i18n/landing';
import type { Lang, TranslationKey } from '../i18n/landing';

const locale = (Astro.currentLocale ?? defaultLocale) as Lang;
const t = (key: TranslationKey): string =>
  (ui[locale] as typeof ui[typeof defaultLocale])[key] ?? ui[defaultLocale][key];

const features = [
  {
    icon: 'lucide:mic',
    title: t('f1-title'),
    desc: t('f1-desc'),
    accent: '#96D21B',
    accent2: '#3486F3',
    surface: '#F4FDE6',
    surface2: '#EDF6FF',
    video: '/en-videos/ai-voice-video.MP4',
    poster: '/en-pic/ai-voice.PNG',
  },
  {
    icon: 'lucide:sparkles',
    title: t('f2-title'),
    desc: t('f2-desc'),
    accent: '#3486F3',
    accent2: '#96D21B',
    surface: '#EEF6FF',
    surface2: '#F5FDEA',
    video: '/en-videos/month-review.MP4',
    poster: '/en-pic/monthly-review.PNG',
  },
  {
    icon: 'lucide:dices',
    title: t('f3-title'),
    desc: t('f3-desc'),
    accent: '#F6B73C',
    accent2: '#3486F3',
    surface: '#FFF7E7',
    surface2: '#EEF6FF',
    video: '/en-videos/gashapon-machine.MP4',
    poster: '/shared-pic/gashapon.PNG',
  },
  {
    icon: 'lucide:notebook-pen',
    title: t('f4-title'),
    desc: t('f4-desc'),
    accent: '#21BFA7',
    accent2: '#96D21B',
    surface: '#EAFBF7',
    surface2: '#F6FDEB',
    video: '/en-videos/note.MP4',
    poster: undefined,
  },
  {
    icon: 'lucide:clock',
    title: t('f5-title'),
    desc: t('f5-desc'),
    accent: '#8B6EF6',
    accent2: '#3486F3',
    surface: '#F3EFFF',
    surface2: '#EDF6FF',
    video: '/en-videos/deadline.MP4',
    poster: '/en-pic/calendar.PNG',
  },
];

// One distinct bun expression per gap between feature cards (4 gaps → 4 faces),
// with bun-happy on the start mark and bun-wink on the end mark, so no two
// buns down the whole section repeat.
const featureBrandMarks = [
  '/shared-pic/buns/bun-grin.svg',
  '/shared-pic/buns/bun-smile.svg',
  '/shared-pic/buns/bun-teary.svg',
  '/shared-pic/buns/bun-sleepy.svg',
] as const;

const featureIconMarks = [
  '/shared-pic/buns/bun-happy.svg',
  '/shared-pic/buns/bun-grin.svg',
  '/shared-pic/buns/bun-smile.svg',
  '/shared-pic/buns/bun-teary.svg',
  '/shared-pic/buns/bun-sleepy.svg',
] as const;

const seo = locale === 'zh'
  ? {
      title: 'BlotzTask | ADHD 任务管理 App 与 AI 待办事项工具',
      description: 'BlotzTask 是 ADHD 友好的 AI 任务管理 App，支持语音创建待办事项、AI 任务拆解、截止日期提醒和成果回顾，帮助你更轻松地开始任务。',
    }
  : {
      title: 'BlotzTask | ADHD-friendly Task Management App',
      description: 'BlotzTask is an ADHD-friendly task management app that helps you capture tasks, break work into clear steps, manage deadlines, and plan with less overwhelm.',
    };

const faqItems = ([1,2,3,4,5,6] as const).map((n) => ({
  '@type': 'Question',
  name: t(`faq-q${n}` as TranslationKey),
  acceptedAnswer: {
    '@type': 'Answer',
    text: t(`faq-a${n}` as TranslationKey),
  },
}));

const jsonLd = [
  {
    '@context': 'https://schema.org',
    '@type': 'WebSite',
    name: 'BlotzTask',
    url: `https://blotz-task-website.vercel.app/${locale}/`,
    inLanguage: locale,
  },
  {
    '@context': 'https://schema.org',
    '@type': 'SoftwareApplication',
    name: 'BlotzTask',
    applicationCategory: 'ProductivityApplication',
    operatingSystem: 'iOS, Android',
    description: seo.description,
    keywords: locale === 'zh'
      ? 'ADHD 任务管理 App, AI 任务管理, ADHD 待办事项 App, 任务拆解 App, 截止日期提醒'
      : 'ADHD task management app, AI task management, ADHD to-do app, task breakdown app, deadline reminder app',
    offers: {
      '@type': 'Offer',
      price: '0',
      priceCurrency: 'USD',
    },
  },
  {
    '@context': 'https://schema.org',
    '@type': 'FAQPage',
    mainEntity: faqItems,
  },
];
---

<Layout
  title={seo.title}
  description={seo.description}
  jsonLd={jsonLd}
>
  <div class="hero-area">
    <!-- HERO -->
    <section class="hero">
      <div class="blob blob-g"></div>
      <div class="blob blob-b"></div>
      <div class="hero-inner">
        <div class="hero-text">
          <div class="hero-eyebrow">
            <span class="hero-badge-stack" aria-hidden="true">
              <span class="hero-badge-bun hbb-1"><img src="/shared-pic/buns/bun-grin.svg" alt="" width="66" height="66" /></span>
              <span class="hero-badge-bun hbb-2"><img src="/shared-pic/buns/bun-wink.svg" alt="" width="66" height="66" /></span>
              <span class="hero-badge-bun hbb-3"><img src="/shared-pic/buns/bun-smile.svg" alt="" width="66" height="66" /></span>
            </span>
            <span>{t('hero-eyebrow')}</span>
          </div>
          <h1 class="hero-title">{t('hero-title')}</h1>
          <p class="hero-subtitle">{t('hero-sub')}</p>
          <a class="hero-cta" href="#download">
            <span>{t('hero-download-cta')}</span>
            <Icon name="lucide:arrow-right" />
          </a>
        </div>
        <div class="hero-phone">
          <div class="bun-cluster" id="hero-bun-cluster">
            <button class="bun-tile bun-tile-main" type="button" aria-label="Blotz bun mascot">
              <img class="bun-face" src="/shared-pic/buns/bun-happy.svg" data-rest="/shared-pic/buns/bun-happy.svg" alt="" width="66" height="66" />
            </button>
            <button class="bun-tile bun-tile-top" type="button" aria-label="Blotz bun mascot">
              <img class="bun-face" src="/shared-pic/buns/bun-wink.svg" data-rest="/shared-pic/buns/bun-wink.svg" alt="" width="66" height="66" />
            </button>
            <button class="bun-tile bun-tile-bot" type="button" aria-label="Blotz bun mascot">
              <img class="bun-face" src="/shared-pic/buns/bun-grin.svg" data-rest="/shared-pic/buns/bun-grin.svg" alt="" width="66" height="66" />
            </button>
          </div>
        </div>
      </div>
      <svg class="hero-wave" viewBox="0 0 1440 70" fill="none" xmlns="http://www.w3.org/2000/svg" preserveAspectRatio="none">
        <path d="M0 35 C360 70 720 0 1080 35 C1260 53 1380 22 1440 35 L1440 70 L0 70 Z" fill="#ffffff"/>
      </svg>
    </section>
  </div>

  <!-- FEATURES -->
  <section class="features" id="features">
    <div class="sec-inner">
      <div class="feature-demo" data-feature-demo>
        <div class="feature-preview">
          <div class="feature-preview-sticky">
            <div class="feature-phone" aria-hidden="true">
              <video
                id="feature-preview-video"
                class="feature-preview-video"
                src={features[0].video}
                poster={features[0].poster}
                autoplay
                muted
                loop
                playsinline
              ></video>
              <div class="feature-phone-glow"></div>
            </div>
          </div>
        </div>

        <div class="feature-list" aria-label={t('feat-title')}>
          <div class="feature-progress" aria-hidden="true">
            <span class="feature-progress-fill"></span>
          </div>
          <div class="feature-start-brand" aria-hidden="true">
            <span class="feature-brand-mark feature-brand-mark-start">
              <img
                src="/shared-pic/buns/bun-happy.svg"
                alt=""
                width="156"
                height="140"
                loading="lazy"
                decoding="async"
              />
            </span>
          </div>
          {features.map((feature, index) => (
            <div
              class:list={['feature-step', { 'feature-step-first': index === 0 }]}
              style={`--feature-accent: ${feature.accent}; --feature-accent-2: ${feature.accent2}; --feature-surface: ${feature.surface}; --feature-surface-2: ${feature.surface2};`}
            >
              <button
                class:list={['feature-card', { active: index === 0 }]}
                type="button"
                data-feature-card
                data-feature-index={index}
                data-video={feature.video}
                data-poster={feature.poster}
              >
                <span class="feature-card-icon">
                  <img src={featureIconMarks[index]} alt="" width="66" height="66" loading="lazy" decoding="async" />
                </span>
                <span class="feature-card-text">
                  <span class="feature-card-title">{feature.title}</span>
                  <span class="feature-card-desc">{feature.desc}</span>
                </span>
                <span class="feature-card-cue" aria-hidden="true"><Icon name="lucide:arrow-right" /></span>
                <span class:list={['feature-card-media', { 'has-fallback': !feature.video }]} aria-hidden="true">
                  <video
                    class="mobile-feature-video"
                    src={feature.video}
                    poster={feature.poster}
                    muted
                    loop
                    playsinline
                    preload="metadata"
                  ></video>
                  {!feature.video && (
                    <span class="feature-media-fallback">
                      <img src={featureIconMarks[index]} alt="" width="66" height="66" loading="lazy" decoding="async" />
                      <span>{feature.title}</span>
                    </span>
                  )}
                </span>
              </button>
              {index < features.length - 1 && (
                <span class="feature-brand-gap" aria-hidden="true">
                  <span class="feature-brand-mark">
                    <img
                      src={featureBrandMarks[index % featureBrandMarks.length]}
                      alt=""
                      width="156"
                      height="140"
                      loading="lazy"
                      decoding="async"
                    />
                  </span>
                </span>
              )}
            </div>
          ))}
          <div class="feature-end-brand" aria-hidden="true">
            <span class="feature-end-mark">
              <img
                src="/shared-pic/buns/bun-wink.svg"
                alt=""
                width="156"
                height="140"
                loading="lazy"
                decoding="async"
              />
            </span>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- FAQ -->
  <section class="faq">
    <div class="faq-inner">
      <h2>{t('faq-title')}</h2>
      <div class="faq-list">
        {([1,2,3,4,5,6] as const).map((n) => (
          <details class="faq-item">
            <summary class="faq-question">
              <span>{t(`faq-q${n}` as TranslationKey)}</span>
              <svg class="faq-chevron" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="6 9 12 15 18 9"/></svg>
            </summary>
            <div class="faq-answer">
              <p>{t(`faq-a${n}` as TranslationKey)}</p>
            </div>
          </details>
        ))}
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="cta" id="download">
    <div class="cta-inner">
      <h2>{t('cta-title')}</h2>
      <p>{t('cta-sub')}</p>
      <div class="cta-btns">
        <a class="cta-btn"
          href="https://apps.apple.com/au/app/blotztask-adhd-time-manager/id6752492404"
          target="_blank" rel="noopener noreferrer">
          <svg width="22" height="22" viewBox="0 0 24 24" fill="currentColor">
            <path d="M18.71 19.5c-.83 1.24-1.71 2.45-3.05 2.47-1.34.03-1.77-.79-3.29-.79-1.53 0-2 .77-3.27.82-1.31.05-2.3-1.32-3.14-2.53C4.25 17 2.94 12.45 4.7 9.39c.87-1.52 2.43-2.48 4.12-2.51 1.28-.02 2.5.87 3.29.87.78 0 2.26-1.07 3.8-.91.65.03 2.47.26 3.64 1.98-.09.06-2.17 1.28-2.15 3.81.03 3.02 2.65 4.03 2.68 4.04-.03.07-.42 1.44-1.38 2.83M13 3.5c.73-.83 1.94-1.46 2.94-1.5.13 1.17-.34 2.35-1.04 3.19-.69.85-1.83 1.51-2.95 1.42-.15-1.15.41-2.35 1.05-3.11z"/>
          </svg>
          App Store
        </a>
        <a class="cta-btn cta-btn-out"
          href="https://play.google.com/store/apps/details?id=com.blotz.blotztask&hl=en"
          target="_blank" rel="noopener noreferrer">
          <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor" xmlns="http://www.w3.org/2000/svg"><path d="M3.609 1.814L13.792 12 3.61 22.186a.996.996 0 0 1-.61-.92V2.734a1 1 0 0 1 .609-.92zm10.89 10.893l2.302 2.302-10.937 6.333 8.635-8.635zm3.199-3.199l2.807 1.626a1 1 0 0 1 0 1.73l-2.808 1.626L15.302 12l2.396-2.492zM5.864 2.658L16.802 8.99l-2.302 2.302-8.636-8.634z"/></svg>
          Google Play
        </a>
      </div>
    </div>
  </section>

  <script>
    const featureCards = Array.from(document.querySelectorAll('[data-feature-card]')) as HTMLElement[];
    const featureList = document.querySelector('.feature-list') as HTMLElement | null;
    const previewVideo = document.getElementById('feature-preview-video') as HTMLVideoElement | null;
    const lightbox = document.getElementById('lightbox')!;
    const lbVideo = document.getElementById('lightbox-video') as HTMLVideoElement;
    const lbClose = document.getElementById('lightbox-close')!;
    const lbPrev = document.getElementById('lightbox-prev')!;
    const lbNext = document.getElementById('lightbox-next')!;
    const lbTitle = document.getElementById('lightbox-title')!;
    const lbDesc = document.getElementById('lightbox-desc')!;
    let currentIndex = 0;
    let activeIndex = 0;
    const reduceMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;

    function loadCard(index: number) {
      const card = featureCards[index];
      lbVideo.src = card.dataset.video!;
      lbVideo.poster = card.dataset.poster ?? '';
      lbTitle.textContent = card.querySelector('.feature-card-title')?.textContent ?? '';
      lbDesc.textContent = card.querySelector('.feature-card-desc')?.textContent ?? '';
      lbVideo.load();
      lbVideo.play().catch(() => {});
    }
    function openLightbox(index: number) {
      currentIndex = index;
      loadCard(index);
      lightbox.classList.add('open');
      document.body.style.overflow = 'hidden';
    }
    function closeLightbox() {
      lightbox.classList.remove('open');
      lbVideo.pause();
      lbVideo.src = '';
      lbVideo.poster = '';
      document.body.style.overflow = '';
    }
    function navigate(dir: number) {
      currentIndex = (currentIndex + dir + featureCards.length) % featureCards.length;
      loadCard(currentIndex);
      setActiveFeature(currentIndex, false);
    }

    function updatePreviewVideo(videoSrc: string) {
      if (!previewVideo || previewVideo.src.endsWith(videoSrc)) return;

      const swapVideo = () => {
        previewVideo.src = videoSrc;
        const activeCard = featureCards[activeIndex];
        previewVideo.poster = activeCard?.dataset.poster ?? '';
        previewVideo.load();
        previewVideo.play().catch(() => {});
        previewVideo.classList.remove('switching');
      };

      if (reduceMotion) {
        swapVideo();
        return;
      }

      previewVideo.classList.add('switching');
      window.setTimeout(swapVideo, 140);
    }

    function setActiveFeature(index: number, updateVideo = true) {
      const card = featureCards[index];
      if (!card) return;

      activeIndex = index;
      featureCards.forEach((item, itemIndex) => {
        item.classList.toggle('active', itemIndex === index);
        item.setAttribute('aria-pressed', String(itemIndex === index));
      });
      featureList?.style.setProperty('--feature-progress', String((index + 1) / featureCards.length));
      if (updateVideo) updatePreviewVideo(card.dataset.video!);
    }

    featureCards.forEach((card, i) => {
      card.setAttribute('aria-pressed', String(i === 0));
      card.addEventListener('focus', () => setActiveFeature(i));
      card.addEventListener('click', () => {
        setActiveFeature(i);
        openLightbox(i);
      });
    });

    if ('IntersectionObserver' in window && featureCards.length) {
      const observer = new IntersectionObserver((entries) => {
        const centered = entries
          .filter((entry) => entry.isIntersecting)
          .sort((a, b) => b.intersectionRatio - a.intersectionRatio)[0];
        const index = centered?.target instanceof HTMLElement
          ? Number(centered.target.dataset.featureIndex)
          : NaN;
        if (Number.isFinite(index) && index !== activeIndex) setActiveFeature(index);
      }, {
        threshold: 0,
        rootMargin: '-46% 0px -46% 0px',
      });

      featureCards.forEach((card) => observer.observe(card));
    }

    const mobileVideos = Array.from(document.querySelectorAll('.mobile-feature-video')) as HTMLVideoElement[];
    if ('IntersectionObserver' in window && mobileVideos.length) {
      const videoObserver = new IntersectionObserver((entries) => {
        entries.forEach((entry) => {
          const video = entry.target as HTMLVideoElement;
          if (entry.isIntersecting) {
            video.play().catch(() => {});
          } else {
            video.pause();
          }
        });
      }, { threshold: 0.45 });

      mobileVideos.forEach((video) => videoObserver.observe(video));
    }

    lbClose.addEventListener('click', closeLightbox);
    lbPrev.addEventListener('click', () => navigate(-1));
    lbNext.addEventListener('click', () => navigate(1));
    lightbox.querySelector('.lightbox-backdrop')!.addEventListener('click', closeLightbox);
    document.addEventListener('keydown', (e) => {
      if (!lightbox.classList.contains('open')) return;
      if (e.key === 'Escape') closeLightbox();
      if (e.key === 'ArrowLeft') navigate(-1);
      if (e.key === 'ArrowRight') navigate(1);
    });
    setActiveFeature(0, false);

    // Reactive hero buns: each tile swaps to a fresh random expression on
    // hover/focus/tap and springs back to its resting face on leave.
    const BUN_FACES = [
      '/shared-pic/buns/bun-happy.svg',
      '/shared-pic/buns/bun-wink.svg',
      '/shared-pic/buns/bun-grin.svg',
      '/shared-pic/buns/bun-smile.svg',
      '/shared-pic/buns/bun-teary.svg',
      '/shared-pic/buns/bun-sleepy.svg',
    ];
    document.querySelectorAll<HTMLElement>('#hero-bun-cluster .bun-tile').forEach((tile) => {
      const face = tile.querySelector('img') as HTMLImageElement | null;
      if (!face) return;
      const rest = face.dataset.rest ?? face.src;
      let current = rest;
      const pop = () => { face.classList.remove('bun-pop'); void face.offsetWidth; face.classList.add('bun-pop'); };
      const swap = () => {
        let next = current;
        while (next === current) next = BUN_FACES[Math.floor(Math.random() * BUN_FACES.length)];
        current = next; face.src = next; pop();
      };
      const reset = () => { current = rest; face.src = rest; pop(); };
      tile.addEventListener('mouseenter', swap);
      tile.addEventListener('mouseleave', reset);
      tile.addEventListener('focus', swap);
      tile.addEventListener('blur', reset);
      tile.addEventListener('click', swap);
    });
  </script>

  <!-- VIDEO LIGHTBOX -->
  <div id="lightbox" class="lightbox" aria-modal="true" role="dialog">
    <div class="lightbox-backdrop"></div>
    <button class="lightbox-close" id="lightbox-close" aria-label="Close">
      <svg width="26" height="26" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round">
        <line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/>
      </svg>
    </button>
    <div class="lightbox-content">
      <h2 class="lightbox-title" id="lightbox-title"></h2>
      <div class="lightbox-body">
        <button class="lightbox-arrow" id="lightbox-prev" aria-label="Previous">
          <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="15 18 9 12 15 6"/></svg>
        </button>
        <video id="lightbox-video" class="lightbox-video" playsinline controls></video>
        <div class="lightbox-info">
          <p class="lightbox-desc" id="lightbox-desc"></p>
        </div>
        <button class="lightbox-arrow" id="lightbox-next" aria-label="Next">
          <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="9 18 15 12 9 6"/></svg>
        </button>
      </div>
    </div>
  </div>
</Layout>

<style is:global>
  .hero { position: relative; background: transparent; }
  .hero-inner {
    position: relative; z-index: 1;
    max-width: 1260px; margin: 0 auto;
    padding: 7rem 2rem 3.5rem;
    display: grid; grid-template-columns: minmax(0, 1fr) 520px; align-items: center; gap: 3.5rem;
  }
  .hero-eyebrow { display: inline-flex; align-items: center; gap: 0.5rem; margin-bottom: 1.1rem; padding: 0.45rem 0.95rem; border-radius: 999px; background: rgba(255,255,255,0.68); border: 1px solid rgba(150,210,27,0.35); font-size: 0.9rem; font-weight: 900; color: var(--text); box-shadow: 0 4px 14px rgba(30,33,64,0.06); backdrop-filter: blur(6px); }
  .hero-title { font-size: clamp(2.25rem, 4.2vw, 4.25rem); font-weight: 900; line-height: 1.12; color: var(--text); max-width: 46rem; margin-bottom: 1rem; }
  .hero-subtitle { max-width: 42rem; color: #374151; font-size: clamp(1rem, 1.7vw, 1.2rem); line-height: 1.75; margin-bottom: 2.2rem; font-weight: 700; }
  .hero-cta { display: inline-flex; align-items: center; gap: 0.6rem; padding: 1rem 1.9rem; border-radius: 16px; background: linear-gradient(135deg, var(--green), var(--blue)); color: white; font-family: 'Nunito', 'PingFang SC', sans-serif; font-weight: 900; font-size: 1.05rem; text-decoration: none; box-shadow: 0 12px 30px -8px rgba(52,134,243,0.55); transition: transform 0.2s ease, box-shadow 0.2s ease; animation: cta-pulse 2.8s ease-in-out infinite; }
  .hero-cta:hover { transform: translateY(-2px) scale(1.02); box-shadow: 0 18px 40px -8px rgba(52,134,243,0.7); animation-play-state: paused; }
  .hero-cta svg { width: 20px; height: 20px; flex-shrink: 0; transition: transform 0.2s ease; }
  .hero-cta:hover svg { transform: translateX(3px); }
  @keyframes cta-pulse { 0%, 100% { box-shadow: 0 12px 30px -8px rgba(52,134,243,0.5); } 50% { box-shadow: 0 12px 38px -6px rgba(52,134,243,0.85); } }
  @media (prefers-reduced-motion: reduce) {
    .hero-cta { animation: none; }
    .bun-tile-main, .bun-tile-top, .bun-tile-bot { animation: none; }
    .bun-pop { animation: none; }
  }
  .hero-phone { display: flex; justify-content: center; }
  @keyframes float { 0%,100% { transform: translateY(0); } 50% { transform: translateY(-12px); } }

  /* interactive hero bun cluster (replaces the app-video showcase) */
