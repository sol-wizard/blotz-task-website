---
import Layout from '../layouts/Layout.astro';
import { Icon } from 'astro-icon/components';
import { defaultLocale } from '../i18n/landing';

const locale = Astro.currentLocale ?? defaultLocale;
const zh = locale === 'zh';
const aboutPath = `/${locale}/about#find-us`;

const c = zh
  ? {
      title: '成为 BlotzTask 赞助者',
      subtitle: '我们正在寻找愿意支持年轻 AI 产品团队的赞助者。',
      introTitle: '我们在寻找什么',
      intro:
        'BlotzTask 正在为 ADHD 用户打造更轻、更聪明的任务管理体验。赞助支持能帮助我们继续投入 AI 功能、产品研发和社区建设。',
      whoTitle: '我们是谁',
      who:
        '我们是一支年轻、热情、执行力强的 startup 团队。团队成员横跨产品、软件架构和 UI/UX 设计，正在用真实用户反馈打磨 BlotzTask。',
      howTitle: '如何成为赞助者',
      how:
        '如果你想支持 BlotzTask，欢迎通过 Our team 页面底部的 Find us on 区域联系或关注我们。',
      cta: '去 Our team 联系我们',
      cards: [
        { icon: 'lucide:sparkles', title: '支持 AI 功能', desc: '帮助我们继续开发 Blotz AI Agent、AI 任务生成和总结体验。' },
        { icon: 'lucide:rocket', title: '支持年轻团队', desc: '让一支有热情、有执行力的小团队更快迭代。' },
        { icon: 'lucide:heart-handshake', title: '支持社区', desc: '帮助 BlotzTask 服务更多需要低摩擦任务管理体验的用户。' },
      ],
    }
  : {
      title: 'Become a BlotzTask sponsor',
      subtitle: 'We are looking for sponsors who want to support a young AI product startup.',
      introTitle: 'What we are looking for',
      intro:
        'BlotzTask is building a calmer, smarter task management experience for ADHD minds. Sponsorship helps us keep investing in AI features, product development, and community growth.',
      whoTitle: 'Who we are',
      who:
        'We are a young, highly enthusiastic startup team with product, software architecture, and UI/UX design experience. We are building BlotzTask with real user feedback and a strong bias toward shipping.',
      howTitle: 'How to become a sponsor',
      how:
        'If you want to support BlotzTask, contact or follow us through the Find us on section at the bottom of the Our team page.',
      cta: 'Talk to Our team',
      cards: [
        { icon: 'lucide:sparkles', title: 'Support AI features', desc: 'Help us build Blotz AI Agent, AI task generation, and smarter review experiences.' },
        { icon: 'lucide:rocket', title: 'Back young talent', desc: 'Support a focused team with strong energy, product taste, and execution speed.' },
        { icon: 'lucide:heart-handshake', title: 'Grow the community', desc: 'Help BlotzTask reach more people who need a lower-friction way to manage tasks.' },
      ],
    };
---

<Layout title={`${c.title} – BlotzTask`}>
  <div class="hero-area">
    <section class="sponsor-hero">
      <div class="sponsor-hero-copy">
        <span class="sponsor-kicker">
          <Icon name="lucide:heart-handshake" width={18} height={18} />
          {zh ? '赞助合作' : 'Sponsor BlotzTask'}
        </span>
        <h1>{c.title}</h1>
        <p>{c.subtitle}</p>
        <a class="sponsor-hero-btn" href={aboutPath}>
          <span>{c.cta}</span>
          <Icon name="lucide:arrow-right" width={19} height={19} />
        </a>
      </div>
      <div class="sponsor-bun" aria-hidden="true">
        <img src="/shared-pic/bun-delighted.svg" alt="" width="39" height="35" loading="lazy" />
      </div>
    </section>
  </div>

  <section class="sponsor-body">
    <div class="sponsor-story">
      <article>
        <h2>{c.introTitle}</h2>
        <p>{c.intro}</p>
      </article>
      <article>
        <h2>{c.whoTitle}</h2>
        <p>{c.who}</p>
      </article>
      <article>
        <h2>{c.howTitle}</h2>
        <p>{c.how}</p>
      </article>
    </div>

    <div class="sponsor-card-grid">
      {c.cards.map((card) => (
        <div class="sponsor-card">
          <div class="sponsor-card-icon"><Icon name={card.icon} width={22} height={22} /></div>
          <h3>{card.title}</h3>
          <p>{card.desc}</p>
        </div>
      ))}
    </div>

    <div class="sponsor-bottom-cta">
      <h2>{zh ? '想聊聊赞助？' : 'Want to talk sponsorship?'}</h2>
      <a href={aboutPath}>
        <span>{c.cta}</span>
        <Icon name="lucide:arrow-right" width={18} height={18} />
      </a>
    </div>
  </section>
</Layout>

<style>
  .sponsor-hero {
    min-height: 540px;
    display: grid;
    grid-template-columns: minmax(0, 1fr) 280px;
    align-items: center;
    gap: 3rem;
    max-width: 1060px;
    margin: 0 auto;
    padding: 8rem 2rem 5rem;
  }
  .sponsor-hero-copy { max-width: 680px; }
  .sponsor-kicker {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    margin-bottom: 1rem;
    padding: 0.45rem 0.9rem;
    border-radius: 999px;
    color: #4d7d09;
    background: rgba(255,255,255,0.7);
    border: 1px solid rgba(150,210,27,0.35);
    font-size: 0.86rem;
    font-weight: 900;
  }
  .sponsor-hero h1 {
    color: var(--text);
    font-size: clamp(2.2rem, 4.2vw, 3.5rem);
    font-weight: 900;
    line-height: 1.14;
    margin-bottom: 1rem;
  }
  .sponsor-hero p {
    color: #374151;
    font-size: 1.13rem;
    line-height: 1.75;
    margin-bottom: 2rem;
  }
  .sponsor-hero-btn {
    display: inline-flex;
    align-items: center;
    gap: 0.6rem;
    min-height: 52px;
    padding: 0.9rem 1.55rem;
    border-radius: 16px;
    color: white;
    background: linear-gradient(135deg, var(--green), var(--blue));
    box-shadow: 0 14px 30px -14px rgba(52,134,243,0.7);
    text-decoration: none;
    font-weight: 900;
    transition: transform 0.18s ease, box-shadow 0.18s ease;
  }
  .sponsor-hero-btn:hover {
    transform: translateY(-2px);
    box-shadow: 0 18px 38px -16px rgba(52,134,243,0.82);
  }
  .sponsor-bun {
    display: grid;
    place-items: center;
    width: 220px;
    height: 220px;
    border-radius: 48px;
    background:
      radial-gradient(circle at 28% 24%, rgba(255,255,255,0.32), transparent 34%),
      linear-gradient(135deg, var(--green), var(--blue));
    box-shadow: 0 24px 70px -28px rgba(52,134,243,0.65);
  }
  .sponsor-bun img {
    width: 116px;
    height: auto;
  }

  .sponsor-body {
    background: #fff;
    padding: 4.5rem 2rem 6rem;
  }
  .sponsor-story {
    max-width: 980px;
    margin: 0 auto;
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1.5rem;
  }
  .sponsor-story article,
  .sponsor-card,
  .sponsor-bottom-cta {
    border: 1px solid #eef0f2;
    border-radius: 22px;
    background: #fff;
    box-shadow: 0 12px 34px -22px rgba(30,33,64,0.28);
  }
  .sponsor-story article {
    padding: 1.75rem 1.5rem;
  }
  .sponsor-story h2 {
    color: var(--text);
    font-size: 1.18rem;
    font-weight: 900;
    margin-bottom: 0.65rem;
  }
  .sponsor-story p,
  .sponsor-card p {
    color: #374151;
    font-size: 0.95rem;
    line-height: 1.7;
  }
  .sponsor-card-grid {
    max-width: 980px;
    margin: 2rem auto 0;
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1.5rem;
  }
  .sponsor-card {
    padding: 1.75rem 1.5rem;
  }
  .sponsor-card-icon {
    display: grid;
    place-items: center;
    width: 48px;
    height: 48px;
    margin-bottom: 1rem;
    border-radius: 14px;
    color: var(--green);
    background: var(--green-light);
  }
  .sponsor-card h3 {
    color: var(--text);
    font-size: 1.12rem;
    font-weight: 900;
    margin-bottom: 0.5rem;
  }
  .sponsor-bottom-cta {
    max-width: 980px;
    margin: 2rem auto 0;
    padding: 2rem;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1.25rem;
  }
  .sponsor-bottom-cta h2 {
    color: var(--text);
    font-size: 1.5rem;
    font-weight: 900;
  }
  .sponsor-bottom-cta a {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    min-height: 46px;
    padding: 0.75rem 1.2rem;
    border-radius: 14px;
    color: white;
    background: linear-gradient(135deg, var(--green), var(--blue));
    text-decoration: none;
    font-weight: 900;
    white-space: nowrap;
  }

  @media (max-width: 820px) {
    .sponsor-hero {
      grid-template-columns: 1fr;
      padding: 7rem 1.25rem 4rem;
      text-align: center;
    }
    .sponsor-hero-copy { margin: 0 auto; }
    .sponsor-bun {
      order: -1;
      width: 156px;
      height: 156px;
      border-radius: 36px;
      margin: 0 auto;
    }
    .sponsor-bun img { width: 82px; }
    .sponsor-story,
    .sponsor-card-grid {
      grid-template-columns: 1fr;
      max-width: 430px;
    }
    .sponsor-bottom-cta {
      max-width: 430px;
      align-items: stretch;
      flex-direction: column;
      text-align: center;
    }
    .sponsor-bottom-cta a { justify-content: center; }
  }
</style>
