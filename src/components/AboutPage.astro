---
import Layout from '../layouts/Layout.astro';
import { Icon } from 'astro-icon/components';
import { aboutUi, defaultLocale } from '../i18n/about';
import type { AboutLang, AboutKey } from '../i18n/about';

const locale = (Astro.currentLocale ?? defaultLocale) as AboutLang;
const t = (key: AboutKey): string =>
  (aboutUi[locale] as typeof aboutUi[typeof defaultLocale])[key] ?? aboutUi[defaultLocale][key];

const teams = [
  { key: 'design',    icon: 'lucide:palette',   color: '#ede0ff', accent: '#a78bfa' },
  { key: 'marketing', icon: 'lucide:megaphone',  color: '#ffd9ef', accent: '#f472b6' },
  { key: 'dev',       icon: 'lucide:code-2',     color: '#d5e9ff', accent: '#3486F3' },
  { key: 'product',   icon: 'lucide:compass',    color: '#e2f7b2', accent: '#8AC936' },
] as const;
---

<Layout title="About – BlotzTask">
  <div class="hero-area">
    <div class="about-hero">
      <div class="blob blob-g"></div>
      <div class="blob blob-b"></div>
      <div class="about-hero-content">
        <h1>{t('title')}</h1>
        <p>{t('subtitle')}</p>
      </div>
    </div>
  </div>
  <svg class="hero-wave" viewBox="0 0 1440 70" fill="none" xmlns="http://www.w3.org/2000/svg" preserveAspectRatio="none">
    <path d="M0 35 C360 70 720 0 1080 35 C1260 53 1380 22 1440 35 L1440 70 L0 70 Z" fill="#ffffff"/>
  </svg>

  <section class="team-section">
    <div class="team-grid">
      {teams.map(({ key, icon, color, accent }) => (
        <div class="team-card" style={`background: ${color};`}>
          <div class="team-icon" style={`background: ${accent}22;`}>
            <Icon name={icon} style={`color: ${accent};`} />
          </div>
          <h3>{t(`${key}-role` as AboutKey)}</h3>
          <p>{t(`${key}-desc` as AboutKey)}</p>
        </div>
      ))}
    </div>
  </section>

  <footer class="footer">
    <p>{t('footer-copy')}</p>
  </footer>
</Layout>

<style is:global>
  .about-hero {
    position: relative; background: transparent;
    overflow: hidden; padding: 8rem 1.5rem 5rem; text-align: center;
  }
  .about-hero-content { position: relative; z-index: 1; }
  .about-hero h1 { font-size: clamp(2rem, 4vw, 3rem); font-weight: 900; color: var(--text); margin-bottom: 1rem; }
  .about-hero p { font-size: 1.1rem; color: #374151; max-width: 540px; margin: 0 auto; line-height: 1.75; }
  .hero-wave { margin-top: -1px; display: block; width: 100%; }
  .team-section { padding: 5rem 1.5rem 6rem; background: white; }
  .team-grid { max-width: 900px; margin: 0 auto; display: grid; grid-template-columns: repeat(2, 1fr); gap: 1.5rem; }
  .team-card { border-radius: 24px; padding: 2rem 1.75rem; display: flex; flex-direction: column; gap: 1rem; }
  .team-icon { width: 52px; height: 52px; border-radius: 14px; display: flex; align-items: center; justify-content: center; }
  .team-icon svg { width: 26px; height: 26px; }
  .team-card h3 { font-size: 1.2rem; font-weight: 900; }
  .team-card p { font-size: 0.95rem; color: #374151; line-height: 1.7; }
  .footer { background: #1E2140; color: rgba(255,255,255,0.5); text-align: center; padding: 2rem 1.5rem; font-size: 0.88rem; }
  @media (max-width: 600px) {
    .team-grid { grid-template-columns: 1fr; }
    .about-hero { padding: 7rem 1rem 4rem; }
  }
</style>
