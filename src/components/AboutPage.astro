---
import Layout from '../layouts/Layout.astro';
import { aboutUi, defaultLocale } from '../i18n/about';
import type { AboutLang, AboutKey } from '../i18n/about';

const locale = (Astro.currentLocale ?? defaultLocale) as AboutLang;
const t = (key: AboutKey): string =>
  (aboutUi[locale] as typeof aboutUi[typeof defaultLocale])[key] ?? aboutUi[defaultLocale][key];

// The three key people. To use a real photo, drop a square image into
// /public/shared-pic/team/ and set `photo` to its path — the card uses it
// automatically and falls back to the bun `avatar` until then.
const team = [
  // NOTE: the two women's photos are a tentative guess — swap the ceo/tech
  // `photo` values if Katherine and Nicole are reversed.
  { key: 'ceo',    name: 'Katherine Jin', avatar: 'avatar9', photo: '/people/1776865979464.png',  accent: '#8AC936', roleColor: '#4d7d09', linkedin: 'https://www.linkedin.com/in/katherine-j-779746193/' },
  { key: 'tech',   name: 'Nicole Nan',    avatar: 'avatar2', photo: '/people/1768978273644.jpeg', accent: '#3486F3', roleColor: '#1f66c9', linkedin: 'https://www.linkedin.com/in/nicole-nan-501a6831b/' },
  { key: 'design', name: 'Guanghan Li',   avatar: 'avatar1', photo: '/people/1771639472356.jpeg', accent: '#a78bfa', roleColor: '#6d4bc4', linkedin: 'https://www.linkedin.com/in/guanghan-li-ab9973258/' },
] as const;
---

<Layout title="Our team – BlotzTask">
  <div class="hero-area">
    <div class="about-hero">
      <div class="blob blob-g"></div>
      <div class="blob blob-b"></div>
      <div class="about-hero-content">
        <h1>{t('title')}</h1>
        <p>{t('subtitle')}</p>
      </div>
    </div>
  </div>
  <svg class="hero-wave" viewBox="0 0 1440 70" fill="none" xmlns="http://www.w3.org/2000/svg" preserveAspectRatio="none">
    <path d="M0 35 C360 70 720 0 1080 35 C1260 53 1380 22 1440 35 L1440 70 L0 70 Z" fill="#ffffff"/>
  </svg>

  <section class="team-section">
    <div class="team-grid">
      {team.map(({ key, name, avatar, photo, accent, roleColor, linkedin }) => (
        <div class="team-card">
          <div class="team-avatar-ring" style={`--ring: ${accent};`}>
            <img
              class="team-photo" src={photo} alt={name} width="120" height="120" loading="lazy"
              data-fallback={`/shared-pic/moods/${avatar}.svg`}
              onerror="this.onerror=null;this.src=this.dataset.fallback;this.classList.replace('team-photo','team-avatar');"
            />
          </div>
          <h3>{name}</h3>
          <p class="team-role" style={`color: ${roleColor};`}>{t(`${key}-role` as AboutKey)}</p>
          <p class="team-tag">{t(`${key}-tag` as AboutKey)}</p>
          <p class="team-bio">{t(`${key}-bio` as AboutKey)}</p>
          <a class="team-linkedin" href={linkedin} target="_blank" rel="noopener noreferrer" aria-label={`${name} on LinkedIn`}>
            <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M20.45 20.45h-3.56v-5.57c0-1.33-.02-3.04-1.85-3.04-1.85 0-2.14 1.45-2.14 2.94v5.67H9.35V9h3.42v1.56h.05c.48-.9 1.64-1.85 3.37-1.85 3.6 0 4.27 2.37 4.27 5.46v6.28zM5.34 7.43a2.06 2.06 0 1 1 0-4.13 2.06 2.06 0 0 1 0 4.13zM7.12 20.45H3.55V9h3.57v11.45zM22.22 0H1.77C.8 0 0 .78 0 1.75v20.5C0 23.2.8 24 1.77 24h20.45c.98 0 1.78-.8 1.78-1.75V1.75C24 .78 23.2 0 22.22 0z"/></svg>
            <span>{t('connect')}</span>
          </a>
        </div>
      ))}
    </div>
  </section>

</Layout>

<style is:global>
  .about-hero {
    position: relative; background: transparent;
    overflow: hidden; padding: 8rem 1.5rem 5rem; text-align: center;
  }
  .about-hero-content { position: relative; z-index: 1; }
  .about-hero h1 { font-size: clamp(2rem, 4vw, 3rem); font-weight: 900; color: var(--text); margin-bottom: 1rem; }
  .about-hero p { font-size: 1.1rem; color: #374151; max-width: 560px; margin: 0 auto; line-height: 1.75; }
  .hero-wave { margin-top: -1px; display: block; width: 100%; }

  .team-section { padding: 5rem 1.5rem 6rem; background: white; }
  .team-grid {
    max-width: 940px; margin: 0 auto;
    display: grid; grid-template-columns: repeat(3, 1fr); gap: 1.75rem;
  }
  .team-card {
    background: white; border: 1px solid #eef0f2; border-radius: 24px;
    padding: 2.25rem 1.5rem 1.75rem;
    display: flex; flex-direction: column; align-items: center; text-align: center; gap: 0.6rem;
    box-shadow: 0 12px 34px -20px rgba(30, 33, 64, 0.28);
    transition: transform 0.22s ease, box-shadow 0.22s ease;
  }
  .team-card:hover {
    transform: translateY(-4px);
    box-shadow: 0 20px 44px -22px rgba(30, 33, 64, 0.38);
  }
  .team-avatar-ring { margin-bottom: 0.4rem; }
  .team-avatar, .team-photo {
    width: 120px; height: 120px; border-radius: 50%; display: block;
    transition: transform 0.28s cubic-bezier(.34, 1.56, .64, 1);
  }
  .team-avatar { filter: drop-shadow(0 6px 14px rgba(30, 33, 64, 0.14)); }
  .team-photo {
    object-fit: cover;
    box-shadow: 0 6px 16px -6px rgba(30, 33, 64, 0.3), 0 0 0 4px var(--ring, #eee);
  }
  .team-card:hover .team-avatar { transform: rotate(-6deg) scale(1.06); }
  .team-card:hover .team-photo { transform: scale(1.04); }
  .team-card h3 { font-size: 1.3rem; font-weight: 900; color: var(--text); margin-bottom: 0.3rem; }
  /* position: bold, high-contrast, sits directly under the name */
  .team-role { font-size: 1rem; font-weight: 900; letter-spacing: 0.01em; line-height: 1.3; }
  /* expertise credential: quieter supporting line, with a divider above the bio */
  .team-tag { font-size: 0.86rem; font-weight: 700; color: #6b7280; line-height: 1.45; margin-top: 0.55rem; }
  .team-bio { font-size: 0.92rem; color: #374151; line-height: 1.65; margin-top: 0.9rem; padding-top: 0.9rem; border-top: 1px solid #eef0f2; width: 100%; }
  .team-linkedin {
    margin-top: 0.65rem; display: inline-flex; align-items: center; gap: 0.4rem;
    padding: 0.45rem 0.9rem; border-radius: 999px;
    font-size: 0.82rem; font-weight: 800; text-decoration: none;
    color: #0a66c2; background: rgba(10, 102, 194, 0.09);
    transition: background 0.16s ease, transform 0.16s ease;
  }
  .team-linkedin:hover { background: rgba(10, 102, 194, 0.16); transform: translateY(-1px); }

  @media (max-width: 820px) {
    .team-grid { grid-template-columns: 1fr; max-width: 380px; }
  }
  @media (max-width: 600px) {
    .about-hero { padding: 7rem 1rem 4rem; }
  }
  @media (prefers-reduced-motion: reduce) {
    .team-card:hover { transform: none; }
    .team-card:hover .team-avatar, .team-card:hover .team-photo { transform: none; }
  }
</style>
