---
import Layout from '../layouts/Layout.astro';
import { Icon } from 'astro-icon/components';
import { aboutUi, defaultLocale } from '../i18n/about';
import type { AboutLang, AboutKey } from '../i18n/about';

const locale = (Astro.currentLocale ?? defaultLocale) as AboutLang;
const t = (key: AboutKey): string =>
  (aboutUi[locale] as typeof aboutUi[typeof defaultLocale])[key] ?? aboutUi[defaultLocale][key];

// The three key people. To use a real photo, drop a square image into
// /public/shared-pic/team/ and set `photo` to its path — the card uses it
// automatically and falls back to the bun `avatar` until then.
const team = [
  // NOTE: the two women's photos are a tentative guess — swap the ceo/tech
  // `photo` values if Katherine and Nicole are reversed.
  { key: 'ceo',    name: 'Katherine Jin', avatar: 'avatar9', photo: '/people/1776865979464.png',  accent: '#8AC936', roleColor: '#4d7d09', mascot: '/shared-pic/bun-delighted.svg', linkedin: 'https://www.linkedin.com/in/katherine-j-779746193/' },
  { key: 'tech',   name: 'Nicole Nan',    avatar: 'avatar2', photo: '/people/1768978273644.jpeg', accent: '#3486F3', roleColor: '#1f66c9', mascot: '/shared-pic/bun-wink.svg', linkedin: 'https://www.linkedin.com/in/nicole-nan-501a6831b/' },
  { key: 'design', name: 'Guanghan Li',   avatar: 'avatar1', photo: '/people/1771639472356.jpeg', accent: '#a78bfa', roleColor: '#6d4bc4', mascot: '/shared-pic/bun-white.svg', linkedin: 'https://www.linkedin.com/in/guanghan-li-ab9973258/' },
] as const;

const description = locale === 'zh'
  ? '认识 BlotzTask 团队：一个专注打造 ADHD 友好 AI 任务管理 App 的产品、技术与设计团队。'
  : 'Meet the BlotzTask team building an ADHD-friendly AI task management app for calmer planning and productivity.';
---

<Layout title={`${t('title')} | BlotzTask`} description={description}>
  <div class="hero-area">
    <div class="about-hero">
      <div class="blob blob-g"></div>
      <div class="blob blob-b"></div>
      <div class="about-hero-content">
        <h1>{t('title')}</h1>
        <p>{t('subtitle')}</p>
      </div>
    </div>
  </div>
  <svg class="hero-wave" viewBox="0 0 1440 70" fill="none" xmlns="http://www.w3.org/2000/svg" preserveAspectRatio="none">
    <path d="M0 35 C360 70 720 0 1080 35 C1260 53 1380 22 1440 35 L1440 70 L0 70 Z" fill="#ffffff"/>
  </svg>

  <section class="team-section">
    <div class="team-grid">
      {team.map(({ key, name, avatar, photo, accent, roleColor, mascot, linkedin }) => (
        <a
          class="team-card"
          style={`--member-accent: ${accent};`}
          href={linkedin}
          target="_blank"
          rel="noopener noreferrer"
          aria-label={`${name} on ${t('connect')}`}
        >
          <div class="team-avatar-ring" style={`--ring: ${accent};`}>
            <img
              class="team-photo" src={photo} alt={name} width="120" height="120" loading="lazy"
              data-fallback={`/shared-pic/moods/${avatar}.svg`}
              onerror="this.onerror=null;this.src=this.dataset.fallback;this.classList.replace('team-photo','team-avatar');"
            />
          </div>
          <h3>{name}</h3>
          <p class="team-role" style={`color: ${roleColor};`}>{t(`${key}-role` as AboutKey)}</p>
          <p class="team-tag">{t(`${key}-tag` as AboutKey)}</p>
          <p class="team-bio">{t(`${key}-bio` as AboutKey)}</p>
          <span class="team-social" aria-hidden="true">
            <img src={mascot} alt="" width="39" height="35" loading="lazy" />
            <span class="linkedin-badge" aria-hidden="true">
              <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor"><path d="M20.45 20.45h-3.56v-5.57c0-1.33-.02-3.04-1.85-3.04-1.85 0-2.14 1.45-2.14 2.94v5.67H9.35V9h3.42v1.56h.05c.48-.9 1.64-1.85 3.37-1.85 3.6 0 4.27 2.37 4.27 5.46v6.28zM5.34 7.43a2.06 2.06 0 1 1 0-4.13 2.06 2.06 0 0 1 0 4.13zM7.12 20.45H3.55V9h3.57v11.45zM22.22 0H1.77C.8 0 0 .78 0 1.75v20.5C0 23.2.8 24 1.77 24h20.45c.98 0 1.78-.8 1.78-1.75V1.75C24 .78 23.2 0 22.22 0z"/></svg>
            </span>
          </span>
        </a>
      ))}
    </div>
  </section>

  <section class="team-contact" id="find-us">
    <div class="team-contact-inner">
      <h2>{t('contact-title')}</h2>
      <p>{t('contact-sub')}</p>
      <div class="team-contact-links">
        <a class="team-contact-card team-contact-rednote"
          href="https://www.xiaohongshu.com/user/profile/67bc12d6000000000e01f09a"
          target="_blank" rel="noopener noreferrer">
          <Icon name="simple-icons:xiaohongshu" width={24} height={24} />
          <span>{t('contact-rn-name')}</span>
        </a>
        <a class="team-contact-card team-contact-instagram"
          href="https://www.instagram.com/blotztask.app/"
          target="_blank" rel="noopener noreferrer">
          <Icon name="simple-icons:instagram" width={24} height={24} />
          <span>{t('contact-ig-name')}</span>
        </a>
        <a class="team-contact-card team-contact-linkedin"
          href="https://www.linkedin.com/company/blotz-app/"
          target="_blank" rel="noopener noreferrer">
          <Icon name="lucide:linkedin" width={24} height={24} />
          <span>{t('contact-li-name')}</span>
        </a>
      </div>
    </div>
  </section>

</Layout>

<style is:global>
  .about-hero {
    position: relative; background: transparent;
    overflow: hidden; padding: 8rem 1.5rem 5rem; text-align: center;
  }
  .about-hero-content { position: relative; z-index: 1; }
  .about-hero h1 { font-size: clamp(2rem, 4vw, 3rem); font-weight: 900; color: var(--text); margin-bottom: 1rem; }
  .about-hero p { font-size: 1.1rem; color: #374151; max-width: 560px; margin: 0 auto; line-height: 1.75; }
  .hero-wave { margin-top: -1px; display: block; width: 100%; }

  .team-section { padding: 5rem 1.5rem 4rem; background: white; }
  .team-grid {
    max-width: 940px; margin: 0 auto;
    display: grid; grid-template-columns: repeat(3, 1fr); gap: 1.75rem;
  }
  .team-card {
    background: white; border: 1px solid #eef0f2; border-radius: 24px;
    padding: 2.25rem 1.5rem 1.75rem;
    min-height: 100%;
    display: flex; flex-direction: column; align-items: center; text-align: center; gap: 0.6rem;
    color: inherit;
    text-decoration: none;
    cursor: pointer;
    box-shadow: 0 12px 34px -20px rgba(30, 33, 64, 0.28);
    transition: transform 0.22s ease, box-shadow 0.22s ease;
  }
  .team-card:hover {
    transform: translateY(-4px);
    box-shadow: 0 20px 44px -22px rgba(30, 33, 64, 0.38);
  }
  .team-card:focus { outline: none; }
  .team-card:focus-visible { outline: 3px solid var(--blue); outline-offset: 5px; }
  .team-avatar-ring { margin-bottom: 0.4rem; }
  .team-avatar, .team-photo {
    width: 120px; height: 120px; border-radius: 50%; display: block;
    transition: transform 0.28s cubic-bezier(.34, 1.56, .64, 1);
  }
  .team-avatar { filter: drop-shadow(0 6px 14px rgba(30, 33, 64, 0.14)); }
  .team-photo {
    object-fit: cover;
    box-shadow: 0 6px 16px -6px rgba(30, 33, 64, 0.3), 0 0 0 4px var(--ring, #eee);
  }
  .team-card:hover .team-avatar { transform: rotate(-6deg) scale(1.06); }
  .team-card:hover .team-photo { transform: scale(1.04); }
  .team-card h3 { font-size: 1.3rem; font-weight: 900; color: var(--text); margin-bottom: 0.3rem; }
  /* position: bold, high-contrast, sits directly under the name */
  .team-role { font-size: 1rem; font-weight: 900; letter-spacing: 0.01em; line-height: 1.3; }
  /* expertise credential: quieter supporting line, with a divider above the bio */
  .team-tag { font-size: 0.86rem; font-weight: 700; color: #6b7280; line-height: 1.45; margin-top: 0.55rem; }
  .team-bio { font-size: 0.92rem; color: #374151; line-height: 1.65; margin-top: 0.9rem; padding-top: 0.9rem; border-top: 1px solid #eef0f2; width: 100%; }
  .team-social {
    position: relative;
    display: grid;
    place-items: center;
    width: 62px;
    height: 62px;
    margin-top: auto;
    border-radius: 20px;
    color: white;
    background:
      radial-gradient(circle at 28% 24%, rgba(255,255,255,0.28), transparent 34%),
      linear-gradient(135deg, var(--member-accent, var(--green)), var(--blue));
    box-shadow: 0 16px 32px -18px rgba(52, 134, 243, 0.72);
    transition: transform 0.16s ease, box-shadow 0.16s ease, filter 0.16s ease;
  }
  .team-social img {
    width: 34px;
    height: auto;
    display: block;
  }
  .linkedin-badge {
    position: absolute;
    right: -5px;
    bottom: -5px;
    display: grid;
    place-items: center;
    width: 24px;
    height: 24px;
    border-radius: 8px;
    color: white;
    background: #0a66c2;
    box-shadow: 0 0 0 4px white, 0 8px 18px -10px rgba(30, 33, 64, 0.65);
  }
  .linkedin-badge svg { width: 14px; height: 14px; }
  .team-card:hover .team-social {
    transform: translateY(-2px) scale(1.03);
    filter: brightness(1.03);
    box-shadow: 0 20px 38px -18px rgba(52, 134, 243, 0.82);
  }

  .team-contact {
    scroll-margin-top: 7rem;
    padding: 4.5rem 1.5rem;
    background: linear-gradient(135deg, #f0fae0 0%, #edf4ff 100%);
  }
  .team-contact-inner {
    max-width: 640px;
    margin: 0 auto;
    text-align: center;
  }
  .team-contact h2 {
    font-size: 2rem;
    font-weight: 900;
    color: var(--text);
    margin-bottom: 0.5rem;
  }
  .team-contact p {
    font-size: 1rem;
    color: var(--muted);
    margin-bottom: 2.5rem;
  }
  .team-contact-links {
    display: flex;
    justify-content: center;
    gap: 1.25rem;
    flex-wrap: wrap;
  }
  .team-contact-card {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: 0.85rem;
    min-height: 54px;
    padding: 0.95rem 1.75rem;
    border-radius: 16px;
    color: white;
    text-decoration: none;
    font-weight: 900;
    font-size: 0.95rem;
    box-shadow: 0 12px 28px -14px rgba(30, 33, 64, 0.38);
    transition: transform 0.18s ease, box-shadow 0.18s ease, filter 0.18s ease;
  }
  .team-contact-card svg { flex-shrink: 0; }
  .team-contact-card:hover {
    transform: translateY(-2px);
    filter: brightness(1.03);
    box-shadow: 0 16px 34px -14px rgba(30, 33, 64, 0.42);
  }
  .team-contact-rednote { background: #ff2442; }
  .team-contact-instagram {
    background: linear-gradient(135deg, #feda75, #fa7e1e 30%, #d62976 60%, #962fbf 85%, #4f5bd5);
  }
  .team-contact-linkedin { background: #0a66c2; }

  @media (max-width: 820px) {
    .team-grid { grid-template-columns: 1fr; max-width: 380px; }
  }
  @media (max-width: 600px) {
    .about-hero { padding: 7rem 1rem 4rem; }
  }
  @media (prefers-reduced-motion: reduce) {
    .team-card:hover { transform: none; }
    .team-card:hover .team-avatar, .team-card:hover .team-photo { transform: none; }
    .team-social, .team-card:hover .team-social { transition: none; transform: none; }
    .team-contact-card, .team-contact-card:hover { transition: none; transform: none; }
  }
</style>
