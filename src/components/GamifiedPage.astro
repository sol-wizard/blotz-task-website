---
import Layout from '../layouts/Layout.astro';
import { Icon } from 'astro-icon/components';
import { featuresUi, defaultLocale } from '../i18n/features';
import type { FeaturesLang, FeaturesKey } from '../i18n/features';
import '../styles/features.css';

const locale = (Astro.currentLocale ?? defaultLocale) as FeaturesLang;
const t = (key: FeaturesKey): string =>
  (featuresUi[locale] as typeof featuresUi[typeof defaultLocale])[key] ?? featuresUi[defaultLocale][key];

const description = locale === 'zh'
  ? 'BlotzTask 的趣味任务管理功能包含扭蛋抽任务和隐藏徽章，帮助你减少选择压力，用更轻松的方式开始任务。'
  : 'BlotzTask gamified features use a Gachapon task picker and hidden badges to reduce choice overload and make starting tasks easier.';
---

<Layout title={`${t('game-title')} | BlotzTask`} description={description}>
  <div class="hero-area">
    <div class="fp-hero">
      <div class="blob blob-g"></div>
      <div class="blob blob-b"></div>
      <div class="fp-hero-content">
        <div class="fp-hero-icon" style="background: rgba(245,158,11,0.13);">
          <Icon name="lucide:dices" style="color: #d97706;" />
        </div>
        <h1>{t('game-title')}</h1>
        <p>{t('game-sub')}</p>
      </div>
    </div>
  </div>
  <svg class="hero-wave" viewBox="0 0 1440 70" fill="none" xmlns="http://www.w3.org/2000/svg" preserveAspectRatio="none">
    <path d="M0 35 C360 70 720 0 1080 35 C1260 53 1380 22 1440 35 L1440 70 L0 70 Z" fill="#ffffff"/>
  </svg>

  <section class="fp-section">
    <div class="fp-section-inner">
      <div class="fp-text">
        <span class="fp-badge">{t('game-f1-badge')}</span>
        <h2>{t('game-f1-title')}</h2>
        <p>{t('game-f1-desc')}</p>
      </div>
      <div class="fp-visual">
        <video class="fp-video" src="/en-videos/gashapon-machine.MP4" autoplay muted loop playsinline></video>
      </div>
    </div>
  </section>

  <section class="fp-section fp-section-alt">
    <div class="fp-section-inner">
      <div class="fp-text">
        <span class="fp-badge">{t('game-f2-badge')}</span>
        <h2>{t('game-f2-title')}</h2>
        <p>{t('game-f2-desc')}</p>
      </div>
      <div class="fp-visual">
        <div class="fp-icon-frame" style="background: linear-gradient(135deg, #fff4c0, #ffd96a);">
          <Icon name="lucide:award" style="color: #b45309;" />
        </div>
      </div>
    </div>
  </section>

  <section class="fp-cta">
    <div class="fp-cta-inner">
      <h2>{t('feat-cta-title')}</h2>
      <p>{t('feat-cta-sub')}</p>
      <div class="fp-cta-btns">
        <a class="fp-cta-btn"
          href="https://apps.apple.com/au/app/blotztask-adhd-time-manager/id6752492404"
          target="_blank" rel="noopener noreferrer">
          <Icon name="simple-icons:apple" width={18} height={18} />
          App Store
        </a>
        <a class="fp-cta-btn fp-cta-btn-out"
          href="https://play.google.com/store/apps/details?id=com.blotz.blotztask&hl=en"
          target="_blank" rel="noopener noreferrer">
          <Icon name="simple-icons:googleplay" width={16} height={16} />
          Google Play
        </a>
      </div>
    </div>
  </section>
</Layout>
