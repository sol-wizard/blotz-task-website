---
import Layout from '../layouts/Layout.astro';
import { Icon } from 'astro-icon/components';
import { defaultLocale } from '../i18n/landing';

const locale = Astro.currentLocale ?? defaultLocale;
const zh = locale === 'zh';

const c = zh
  ? {
      title: '路线图更新中',
      subtitle: '我们正在准备 BlotzTask v2.0。',
      body: '下一阶段会围绕更多 AI 功能、Blotz AI Agent、更智能的任务生成与回顾体验展开。路线图页面暂时先保持简单，等方向更明确后再正式更新。',
      badge: 'v2.0 正在规划',
      cta: '敬请期待',
    }
  : {
      title: 'Roadmap in progress',
      subtitle: 'We are working on BlotzTask v2.0.',
      body: 'The next phase will focus on more AI features, the Blotz AI agent, smarter task generation, and better review experiences. This roadmap page is temporary while we shape the next version.',
      badge: 'v2.0 is being planned',
      cta: 'Stay tuned',
    };
---

<Layout title={`${c.title} – BlotzTask`}>
  <div class="hero-area">
    <section class="roadmap-hold">
      <div class="roadmap-card">
        <span class="roadmap-badge">
          <Icon name="lucide:sparkles" width={18} height={18} />
          {c.badge}
        </span>
        <h1>{c.title}</h1>
        <p class="roadmap-subtitle">{c.subtitle}</p>
        <p class="roadmap-body-copy">{c.body}</p>
        <div class="roadmap-status">
          <img src="/shared-pic/bun-wink.svg" alt="" width="39" height="35" loading="lazy" />
          <span>{c.cta}</span>
        </div>
      </div>
    </section>
  </div>
</Layout>

<style>
  .roadmap-hold {
    min-height: calc(100vh - 180px);
    display: grid;
    place-items: center;
    padding: 8rem 1.5rem 6rem;
  }
  .roadmap-card {
    width: min(720px, 100%);
    padding: clamp(2rem, 5vw, 4rem);
    border: 1px solid rgba(30,33,64,0.08);
    border-radius: 28px;
    background: rgba(255,255,255,0.72);
    box-shadow: 0 24px 70px -44px rgba(30,33,64,0.42);
    backdrop-filter: blur(16px);
    -webkit-backdrop-filter: blur(16px);
    text-align: center;
  }
  .roadmap-badge {
    display: inline-flex;
    align-items: center;
    gap: 0.45rem;
    margin-bottom: 1.25rem;
    padding: 0.45rem 0.85rem;
    border-radius: 999px;
    color: #4d7d09;
    background: rgba(150,210,27,0.18);
    font-size: 0.84rem;
    font-weight: 900;
  }
  .roadmap-card h1 {
    color: var(--text);
    font-size: clamp(2rem, 4vw, 3rem);
    font-weight: 900;
    line-height: 1.15;
    margin-bottom: 0.85rem;
  }
  .roadmap-subtitle {
    color: #374151;
    font-size: 1.2rem;
    font-weight: 800;
    margin-bottom: 1rem;
  }
  .roadmap-body-copy {
    max-width: 560px;
    margin: 0 auto;
    color: #4b5563;
    font-size: 1rem;
    line-height: 1.8;
  }
  .roadmap-status {
    display: inline-flex;
    align-items: center;
    gap: 0.75rem;
    margin-top: 2rem;
    padding: 0.75rem 1.05rem;
    border-radius: 18px;
    color: white;
    background: linear-gradient(135deg, var(--green), var(--blue));
    box-shadow: 0 14px 30px -16px rgba(52,134,243,0.72);
    font-weight: 900;
  }
  .roadmap-status img {
    width: 28px;
    height: auto;
  }
</style>
