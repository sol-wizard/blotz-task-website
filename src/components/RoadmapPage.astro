---
import Layout from '../layouts/Layout.astro';
import { Icon } from 'astro-icon/components';
import { defaultLocale } from '../i18n/landing';

const locale = Astro.currentLocale ?? defaultLocale;
const zh = locale === 'zh';

const c = zh
  ? {
      title: '路线图即将更新',
      subtitle: 'BlotzTask v2.0 正在成形。',
      body: '更多 AI 捕捉、更智能回顾、更轻松的计划体验。',
      badge: 'v2.0 规划中',
      cta: '敬请期待',
    }
  : {
      title: 'Roadmap coming soon',
      subtitle: 'BlotzTask v2.0 is taking shape.',
      body: 'More AI capture, smarter reviews, and calmer planning.',
      badge: 'v2.0 planning',
      cta: 'Stay tuned',
    };
---

<Layout title={`${c.title} – BlotzTask`}>
  <div class="hero-area">
    <section class="roadmap-hold">
      <div class="roadmap-card">
        <span class="roadmap-badge">
          <Icon name="lucide:sparkles" width={18} height={18} />
          {c.badge}
        </span>
        <h1>{c.title}</h1>
        <p class="roadmap-subtitle">{c.subtitle}</p>
        <p class="roadmap-body-copy">{c.body}</p>
        <a class="roadmap-status" href={`/${locale}/about#find-us`}>
          <Icon name="lucide:bell-ring" width={22} height={22} />
          <span>{c.cta}</span>
        </a>
      </div>
    </section>
  </div>
</Layout>

<style>
  .roadmap-hold {
    min-height: calc(100vh - 180px);
    display: grid;
    place-items: center;
    padding: 8rem 1.5rem 6rem;
  }
  .roadmap-card {
    width: min(720px, 100%);
    padding: clamp(2rem, 5vw, 3.5rem);
    border: 1px solid rgba(30,33,64,0.08);
    border-radius: 28px;
    background: rgba(255,255,255,0.72);
    box-shadow: 0 24px 70px -44px rgba(30,33,64,0.42);
    backdrop-filter: blur(16px);
    -webkit-backdrop-filter: blur(16px);
    text-align: center;
  }
  .roadmap-badge {
    display: inline-flex;
    align-items: center;
    gap: 0.45rem;
    margin-bottom: 1.25rem;
    padding: 0.45rem 0.85rem;
    border-radius: 999px;
    color: #4d7d09;
    background: rgba(150,210,27,0.18);
    font-size: 0.84rem;
    font-weight: 900;
  }
  .roadmap-card h1 {
    color: var(--text);
    font-size: clamp(2rem, 4vw, 3.15rem);
    font-weight: 900;
    line-height: 1.15;
    margin-bottom: 0.85rem;
  }
  .roadmap-subtitle {
    color: #374151;
    font-size: 1.2rem;
    font-weight: 800;
    margin-bottom: 1rem;
  }
  .roadmap-body-copy {
    max-width: 560px;
    margin: 0 auto;
    color: #4b5563;
    font-size: 1.05rem;
    line-height: 1.55;
  }
  .roadmap-status {
    display: inline-flex;
    align-items: center;
    gap: 0.75rem;
    margin-top: 2rem;
    padding: 0.85rem 1.5rem;
    border-radius: 18px;
    color: white;
    text-decoration: none;
    background: linear-gradient(135deg, var(--green), var(--blue));
    box-shadow: 0 14px 30px -16px rgba(52,134,243,0.72);
    font-weight: 900;
    transition: transform 0.18s ease, box-shadow 0.18s ease, filter 0.18s ease;
  }
  .roadmap-status svg {
    flex-shrink: 0;
  }
  .roadmap-status:hover {
    transform: translateY(-2px);
    filter: brightness(1.03);
    box-shadow: 0 18px 38px -16px rgba(52,134,243,0.8);
  }
  @media (prefers-reduced-motion: reduce) {
    .roadmap-status, .roadmap-status:hover { transition: none; transform: none; }
  }
</style>
