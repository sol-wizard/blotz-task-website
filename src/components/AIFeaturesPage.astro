---
import Layout from '../layouts/Layout.astro';
import { Icon } from 'astro-icon/components';
import { featuresUi, defaultLocale } from '../i18n/features';
import type { FeaturesLang, FeaturesKey } from '../i18n/features';
import '../styles/features.css';

const locale = (Astro.currentLocale ?? defaultLocale) as FeaturesLang;
const t = (key: FeaturesKey): string =>
  (featuresUi[locale] as typeof featuresUi[typeof defaultLocale])[key] ?? featuresUi[defaultLocale][key];

const description = locale === 'zh'
  ? '了解 BlotzTask 的 AI 功能：语音记录、AI 任务拆解、周报月报回顾，帮助 ADHD 用户更轻松地开始行动。'
  : 'Explore BlotzTask AI features for ADHD task management, including voice input, task breakdown, and weekly or monthly progress reviews.';
---

<Layout title={`${t('ai-title')} | BlotzTask`} description={description}>
  <div class="hero-area">
    <div class="fp-hero">
      <div class="blob blob-g"></div>
      <div class="blob blob-b"></div>
      <div class="fp-hero-content">
        <div class="fp-hero-icon" style="background: rgba(52,134,243,0.12);">
          <Icon name="lucide:sparkles" style="color: #3486F3;" />
        </div>
        <h1>{t('ai-title')}</h1>
        <p>{t('ai-sub')}</p>
      </div>
    </div>
  </div>
  <svg class="hero-wave" viewBox="0 0 1440 70" fill="none" xmlns="http://www.w3.org/2000/svg" preserveAspectRatio="none">
    <path d="M0 35 C360 70 720 0 1080 35 C1260 53 1380 22 1440 35 L1440 70 L0 70 Z" fill="#ffffff"/>
  </svg>

  <section class="fp-section">
    <div class="fp-section-inner">
      <div class="fp-text">
        <span class="fp-badge">{t('ai-f1-badge')}</span>
        <h2>{t('ai-f1-title')}</h2>
        <p>{t('ai-f1-desc')}</p>
      </div>
      <div class="fp-visual">
        <video class="fp-video" src="/en-videos/ai-voice-video.MP4" autoplay muted loop playsinline></video>
      </div>
    </div>
  </section>

  <section class="fp-section fp-section-alt">
    <div class="fp-section-inner">
      <div class="fp-text">
        <span class="fp-badge">{t('ai-f2-badge')}</span>
        <h2>{t('ai-f2-title')}</h2>
        <p>{t('ai-f2-desc')}</p>
      </div>
      <div class="fp-visual">
        <div class="fp-icon-frame" style="background: linear-gradient(135deg, #bde2fc, #8ec8fc);">
          <Icon name="lucide:git-branch" style="color: #1d5fbf;" />
        </div>
      </div>
    </div>
  </section>

  <section class="fp-section">
    <div class="fp-section-inner">
      <div class="fp-text">
        <span class="fp-badge">{t('ai-f3-badge')}</span>
        <h2>{t('ai-f3-title')}</h2>
        <p>{t('ai-f3-desc')}</p>
      </div>
      <div class="fp-visual">
        <video class="fp-video" src="/en-videos/month-review.MP4" autoplay muted loop playsinline></video>
      </div>
    </div>
  </section>

  <section class="fp-cta">
    <div class="fp-cta-inner">
      <h2>{t('feat-cta-title')}</h2>
      <p>{t('feat-cta-sub')}</p>
      <div class="fp-cta-btns">
        <a class="fp-cta-btn"
          href="https://apps.apple.com/au/app/blotztask-adhd-time-manager/id6752492404"
          target="_blank" rel="noopener noreferrer">
          <Icon name="simple-icons:apple" width={18} height={18} />
          App Store
        </a>
        <a class="fp-cta-btn fp-cta-btn-out"
          href="https://play.google.com/store/apps/details?id=com.blotz.blotztask&hl=en"
          target="_blank" rel="noopener noreferrer">
          <Icon name="simple-icons:googleplay" width={16} height={16} />
          Google Play
        </a>
      </div>
    </div>
  </section>
</Layout>
