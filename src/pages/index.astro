        'f4-title': 'Quick Notes',
        'f4-desc': 'Capture thoughts and ideas instantly — nothing slips through the cracks.',
        'f5-title': 'Deadline Tracker',
        'f5-desc': 'Mark tasks as deadlines and always know how many days remain. Stay on top of what matters most without the anxiety.',
        'cta-title': 'Ready to take control?',
        'cta-sub': 'Download BlotzTask and start managing your ADHD tasks with ease.',
        'cta-ios': '📱 App Store',
        'cta-and': '🤖 Google Play',
        'footer-copy': '© 2025 BlotzTask. Made with ❤️ for the ADHD community.',
        'feedback-title': 'We Want to Hear from You',
        'feedback-sub': 'Help us improve Blotz by sharing your ideas and feedback. Your input shapes the future of AI-powered task management.',
        'feedback-btn-label': 'Share Your Feedback',
        'contact-title': 'Find us on',
        'contact-sub': 'Follow BlotzTask for updates, tips, and community.',
        'contact-rn-sub': 'Follow us on',
        'contact-rn-name': 'Red Note',
        'contact-li-sub': 'Connect on',
        'contact-li-name': 'LinkedIn',
      },
      zh: {
        langLabel: 'English',
        'hero-badge': '✨ AI驱动的ADHD助手',
        'hero-title': '专为ADHD设计的AI任务管理方式！',
        'hero-sub': '用AI轻松管理你的日常任务：快速生成任务 • AI拆解 • 随时记录',
        'dl-ios-s': '下载于',
        'dl-and-s': '获取于',
        'feat-title': '核心功能',
        'feat-sub': '你需要的一切，都在这里',
        'f1-title': '语音生成任务',
        'f1-desc': '通过语音输入，AI自动生成并拆解任务，还提供每月和每周的详细进度报告。',
        'f1-p1': '🤖 AI拆解',
        'f1-p2': '📊 周月报告',
        'f2-title': 'AI总结回顾',
        'f2-desc': '让AI为你总结过去一周或一个月完成的所有任务，见证你的每一步进步。',
        'f3-title': '扭蛋机随机任务',
        'f3-desc': '不知道从哪开始？让扭蛋机帮你随机选一个任务，轻松破冰启动！',
        'f4-title': '快速笔记',
        'f4-desc': '随时随地记录任何想法，灵感永不丢失。',
        'f5-title': '截止日期追踪',
        'f5-desc': '将重要任务设为截止日期，随时掌握剩余天数，不再错过任何期限。',
        'cta-title': '准备好掌控你的任务了吗？',
        'cta-sub': '立即下载BlotzTask，轻松管理你的ADHD任务。',
        'cta-ios': '📱 App Store',
        'cta-and': '🤖 Google Play',
        'footer-copy': '© 2025 BlotzTask. 用❤️为ADHD社区打造。',
        'feedback-title': '我们想听听你的声音',
        'feedback-sub': '通过分享你的想法和反馈，帮助我们改进 Blotz。你的意见将塑造 AI 驱动任务管理的未来。',
        'feedback-btn-label': '分享你的反馈',
        'contact-title': '关注我们',
        'contact-sub': '关注 BlotzTask，获取最新动态、使用技巧和社区资讯。',
        'contact-rn-sub': '关注我们',
        'contact-rn-name': '小红书',
        'contact-li-sub': '联系我们',
        'contact-li-name': 'LinkedIn',
      }
    };

    const fanCards = Array.from(document.querySelectorAll('.fan-card')) as HTMLElement[];
    const lightbox = document.getElementById('lightbox')!;
    const lbVideo = document.getElementById('lightbox-video') as HTMLVideoElement;
    const lbClose = document.getElementById('lightbox-close')!;
    const lbPrev = document.getElementById('lightbox-prev')!;
    const lbNext = document.getElementById('lightbox-next')!;
    const lbTitle = document.getElementById('lightbox-title')!;
    const lbDesc = document.getElementById('lightbox-desc')!;

    let currentIndex = 0;

    function loadCard(index: number) {
      const card = fanCards[index];
      lbVideo.src = card.dataset.video!;
      lbTitle.textContent = card.querySelector('.fan-label')?.textContent ?? '';
      lbDesc.textContent = card.querySelector('.fan-desc')?.textContent ?? '';
      lbVideo.load();
      lbVideo.play();
    }

    function openLightbox(index: number) {
      currentIndex = index;
      loadCard(index);
      lightbox.classList.add('open');
      document.body.style.overflow = 'hidden';
    }

    function closeLightbox() {
      lightbox.classList.remove('open');
      lbVideo.pause();
      lbVideo.src = '';
      document.body.style.overflow = '';
    }

    function navigate(dir: number) {
      currentIndex = (currentIndex + dir + fanCards.length) % fanCards.length;
      loadCard(currentIndex);
    }

    fanCards[2]?.classList.add('active');
    fanCards.forEach((card, i) => {
      card.addEventListener('click', () => {
        fanCards.forEach(c => c.classList.remove('active'));
        card.classList.add('active');
        openLightbox(i);
      });
    });

    lbClose.addEventListener('click', closeLightbox);
    lbPrev.addEventListener('click', () => navigate(-1));
    lbNext.addEventListener('click', () => navigate(1));
    lightbox.querySelector('.lightbox-backdrop')!.addEventListener('click', closeLightbox);
    document.addEventListener('keydown', (e) => {
      if (!lightbox.classList.contains('open')) return;
      if (e.key === 'Escape') closeLightbox();
      if (e.key === 'ArrowLeft') navigate(-1);
      if (e.key === 'ArrowRight') navigate(1);
    });

    let currentLang: 'en' | 'zh' = 'en';

    const heroVideo = document.getElementById('hero-video') as HTMLVideoElement;
    if (heroVideo) {
      heroVideo.playbackRate = 3;
      heroVideo.addEventListener('loadedmetadata', () => { heroVideo.playbackRate = 3; });
    }

    document.getElementById('lang-toggle')?.addEventListener('click', toggleLang);

    function toggleLang() {
      currentLang = currentLang === 'en' ? 'zh' : 'en';
      const d: Record<string, string> = translations[currentLang];
      document.getElementById('html-root')?.setAttribute('lang', currentLang);
      const langLabel = document.getElementById('lang-label');
      if (langLabel) langLabel.textContent = d.langLabel;
      for (const [id, val] of Object.entries(d)) {
        if (id === 'langLabel') continue;
        const el = document.getElementById(id);
        if (el) el.textContent = val;
      }
    }
  </script>
  <!-- VIDEO LIGHTBOX -->
  <div id="lightbox" class="lightbox" aria-modal="true" role="dialog">
    <div class="lightbox-backdrop"></div>
    <button class="lightbox-close" id="lightbox-close" aria-label="Close">
      <svg width="26" height="26" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round">
        <line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/>
      </svg>
    </button>
    <div class="lightbox-content">
      <h2 class="lightbox-title" id="lightbox-title"></h2>
      <div class="lightbox-body">
        <button class="lightbox-arrow" id="lightbox-prev" aria-label="Previous">
          <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
            <polyline points="15 18 9 12 15 6"/>
          </svg>
        </button>
        <video id="lightbox-video" class="lightbox-video" playsinline controls></video>
        <div class="lightbox-info">
          <p class="lightbox-desc" id="lightbox-desc"></p>
        </div>
        <button class="lightbox-arrow" id="lightbox-next" aria-label="Next">
          <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
            <polyline points="9 18 15 12 9 6"/>
          </svg>
        </button>
      </div>
    </div>
  </div>

</body>
