---
import { Icon } from 'astro-icon/components';
---

<!DOCTYPE html>
<html lang="en" id="html-root">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>BlotzTask – AI-Powered ADHD Task Manager</title>
  <meta name="description" content="The AI-powered way to manage ADHD tasks. Quick task generation, AI breakdown, and easy capture." />
  <link rel="icon" type="image/png" href="/shared-pic/bun-icon.png" />
  <link rel="apple-touch-icon" href="/shared-pic/bun-icon.png" />
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Nunito:wght@400;600;700;800;900&display=swap" rel="stylesheet" />
  <style is:global>
    :root {
      --green: #96D21B;
      --blue: #3486F3;
      --green-light: #EAF8C7;
      --blue-light: #D5E9FF;
      --bg: #ffffff;
      --text: #1E2140;
      --muted: #6B7280;
      --radius: 20px;
      --shadow: 0 4px 24px rgba(0,0,0,0.08);
      --shadow-lg: 0 8px 40px rgba(0,0,0,0.14);
    }
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
    html { scroll-behavior: smooth; }
    body {
      font-family: 'Nunito', 'PingFang SC', 'Microsoft YaHei', system-ui, sans-serif;
      background: var(--bg);
      color: var(--text);
      line-height: 1.6;
    }

    /* HERO AREA (nav + hero share one gradient) */
    .hero-area {
      background: linear-gradient(135deg, #e5f7bf 0%, #edf4ff 55%, #d2e8ff 100%);
      overflow: hidden;
    }

    /* NAV */
    .nav {
      position: sticky; top: 0; z-index: 100;
      background: transparent;
    }
    .nav-inner {
      max-width: 1100px; margin: 0 auto;
      padding: 1rem 1.5rem;
      display: flex; align-items: center; justify-content: space-between;
    }
    .logo {
      display: flex; align-items: center; gap: 0.6rem;
      text-decoration: none; font-weight: 900; font-size: 1.25rem; color: var(--text);
    }
    .logo-mark {
      width: 36px; height: 36px;
      background: linear-gradient(135deg, var(--green), var(--blue));
      border-radius: 10px;
      display: flex; align-items: center; justify-content: center;
      color: white; font-weight: 900; font-size: 1.1rem;
    }
    .lang-btn {
      background: var(--green-light);
      border: 2px solid var(--green);
      color: #3d6b00;
      font-family: 'Nunito', 'PingFang SC', sans-serif;
      font-weight: 700; font-size: 0.9rem;
      padding: 0.4rem 1.1rem; border-radius: 999px; cursor: pointer;
      transition: background 0.2s, color 0.2s;
    }
    .lang-btn:hover { background: var(--green); color: white; }

    /* HERO */
    .hero {
      position: relative;
      background: transparent;
    }
    .blob {
      position: absolute; border-radius: 50%;
      filter: blur(80px); opacity: 0.32; pointer-events: none;
    }
    .blob-g {
      width: 480px; height: 480px; background: var(--green);
      top: -180px; left: -120px;
      animation: blobMove 9s ease-in-out infinite;
    }
    .blob-b {
      width: 380px; height: 380px; background: var(--blue);
      bottom: 20px; right: -80px;
      animation: blobMove 12s ease-in-out infinite reverse;
    }
    @keyframes blobMove {
      0%,100% { transform: translate(0,0); }
      33% { transform: translate(15px,-25px); }
      66% { transform: translate(-10px,15px); }
    }
    .hero-inner {
      position: relative; z-index: 1;
      max-width: 1100px; margin: 0 auto;
      padding: 5rem 1.5rem 3.5rem;
      display: grid; grid-template-columns: 1fr 480px; align-items: center; gap: 3rem;
    }
    .hero-badge {
      display: inline-block;
      background: white; color: var(--text);
      padding: 0.35rem 1rem; border-radius: 999px;
      font-size: 0.85rem; font-weight: 700;
      box-shadow: 0 2px 14px rgba(0,0,0,0.1);
      margin-bottom: 1.25rem;
    }
    .hero-title {
      font-size: clamp(2rem, 3.5vw, 3.1rem);
      font-weight: 900; line-height: 1.2;
      color: var(--text); margin-bottom: 1rem;
    }
    .hero-sub {
      font-size: 1.05rem; color: #374151;
      margin-bottom: 2rem; line-height: 1.75;
    }
    .hero-downloads { display: flex; flex-wrap: wrap; gap: 0.75rem; }
    .dl-btn {
      display: flex; align-items: center; gap: 0.75rem;
      padding: 0.8rem 1.5rem; border-radius: 14px;
      text-decoration: none;
      transition: transform 0.2s, box-shadow 0.2s;
    }
    .dl-btn:hover { transform: translateY(-2px); box-shadow: var(--shadow-lg); }
    .dl-btn > div { display: flex; flex-direction: column; }
    .dl-small { font-size: 0.68rem; font-weight: 600; opacity: 0.8; line-height: 1; }
    .dl-big { font-size: 1rem; font-weight: 800; line-height: 1.3; }
    .dl-ios { background: #1a1a2e; color: white; }
    .dl-and { background: var(--green); color: white; }

    /* HERO VIDEO */
    .hero-phone { display: flex; justify-content: center; }
    .phone-wrap { position: relative; animation: float 4s ease-in-out infinite; }
    @keyframes float { 0%,100% { transform: translateY(0); } 50% { transform: translateY(-12px); } }
    .hero-video {
      width: 260px;
      border-radius: 38px;
      box-shadow: 0 30px 80px rgba(52,134,243,0.25), 0 0 0 1px rgba(255,255,255,0.08);
      display: block;
      position: relative; z-index: 1;
    }
    .phone-glow {
      position: absolute; width: 180px; height: 180px;
      background: radial-gradient(circle, rgba(150,210,27,0.4), transparent 70%);
      bottom: -55px; left: 50%; transform: translateX(-50%);
      border-radius: 50%; filter: blur(20px); z-index: 0;
    }

    /* WAVE DIVIDER */
    .hero-wave { margin-top: -1px; display: block; width: 100%; }

    /* FEATURES */
    .features { padding: 4rem 0 5rem; overflow: hidden; background: white; }
    .sec-inner { max-width: 1100px; margin: 0 auto; }
    .sec-head { text-align: center; margin-bottom: 0; padding: 0 1.5rem 0.5rem; }
    .sec-head h2 { font-size: 2.2rem; font-weight: 900; color: var(--text); margin-bottom: 0.5rem; }
    .sec-head p { font-size: 1.05rem; color: var(--muted); }

    .feat-fan {
      display: flex;
      justify-content: center;
      align-items: flex-end;
      padding: 3.5rem 2rem 5rem;
    }
    .fan-card {
      width: 210px;
      min-height: 290px;
      border-radius: 26px;
      padding: 1.6rem 1.4rem 1.5rem;
      flex-shrink: 0;
      margin: 0 -20px;
      position: relative;
      box-shadow: 0 8px 28px rgba(0,0,0,0.10);
      cursor: pointer;
      transition: transform 0.4s cubic-bezier(0.34, 1.56, 0.64, 1), box-shadow 0.35s ease;
      display: flex;
      flex-direction: column;
      gap: 0.5rem;
      user-select: none;
    }
    .fan-card:nth-child(1) { transform: rotate(-15deg) translateY(38px); z-index: 1; background: linear-gradient(155deg, #e2f7b2, #cff086); }
    .fan-card:nth-child(2) { transform: rotate(-7deg) translateY(18px); z-index: 2; background: linear-gradient(155deg, #d5e9ff, #b8d8ff); }
    .fan-card:nth-child(3) { transform: rotate(0deg) translateY(0); z-index: 5; background: linear-gradient(155deg, #ede0ff, #d5bdff); }
    .fan-card:nth-child(4) { transform: rotate(7deg) translateY(18px); z-index: 2; background: linear-gradient(155deg, #ffd9ef, #ffbfe4); }
    .fan-card:nth-child(5) { transform: rotate(15deg) translateY(38px); z-index: 1; background: linear-gradient(155deg, #fff0c0, #ffe48a); }
    .fan-card.active {
      transform: rotate(0deg) translateY(-18px) scale(1.06) !important;
      z-index: 10 !important;
      box-shadow: 0 24px 60px rgba(0,0,0,0.18) !important;
    }
    .fan-card:not(.active):hover {
      transform: rotate(0deg) translateY(-8px) !important;
      z-index: 8 !important;
      box-shadow: 0 14px 40px rgba(0,0,0,0.14) !important;
    }
    .fan-icon { flex-shrink: 0; }
    .fan-icon svg { width: 2.4rem; height: 2.4rem; stroke-width: 1.5; color: var(--text); }
    .fan-label { font-size: 1rem; font-weight: 800; color: var(--text); margin-top: auto; padding-top: 0.5rem; }
    .fan-desc {
      font-size: 0.8rem; color: #374151; line-height: 1.6;
    }
    .fan-pills { display: flex; gap: 0.35rem; flex-wrap: wrap; }
    .fan-pills span {
      font-size: 0.72rem; font-weight: 700;
      padding: 0.2rem 0.6rem; border-radius: 999px;
      background: rgba(255,255,255,0.55); color: #1E2140;
    }

    /* CTA */
    .cta {
      background: linear-gradient(135deg, var(--green) 0%, var(--blue) 100%);
      padding: 5rem 1.5rem; text-align: center; color: white;
      position: relative; overflow: hidden;
    }
    .cta::before, .cta::after {
      content: ''; position: absolute; border-radius: 50%;
      background: rgba(255,255,255,0.08);
    }
    .cta::before { width: 400px; height: 400px; top: -160px; left: -100px; }
    .cta::after { width: 280px; height: 280px; bottom: -100px; right: -60px; }
    .cta-inner { position: relative; z-index: 1; max-width: 600px; margin: 0 auto; }
    .cta h2 { font-size: 2.4rem; font-weight: 900; margin-bottom: 0.75rem; }
    .cta p { font-size: 1.05rem; opacity: 0.92; margin-bottom: 2rem; }
    .cta-btns { display: flex; justify-content: center; gap: 1rem; flex-wrap: wrap; }
    .cta-btn {
      display: inline-flex; align-items: center; gap: 0.55rem;
      padding: 0.85rem 2rem; border-radius: 14px;
      font-family: 'Nunito', 'PingFang SC', sans-serif;
      font-weight: 800; font-size: 1rem;
      text-decoration: none; background: white; color: var(--text);
      transition: transform 0.2s, box-shadow 0.2s;
    }
    .cta-btn:hover { transform: translateY(-2px); box-shadow: 0 8px 24px rgba(0,0,0,0.2); }
    .cta-btn-out { background: transparent; border: 2px solid white; color: white; }

    /* FOOTER */
    .footer {
      background: #1E2140; color: rgba(255,255,255,0.5);
      text-align: center; padding: 2rem 1.5rem; font-size: 0.88rem;
    }

    /* RESPONSIVE */
    @media (max-width: 900px) {
      .hero-inner { grid-template-columns: 1fr; padding-top: 3.5rem; }
      .hero-phone { order: -1; }
      .fan-card { width: 180px; min-height: 255px; margin: 0 -16px; }
    }
    @media (max-width: 600px) {
      .hero-inner { padding: 3rem 1rem 2.5rem; }
      .hero-downloads { flex-direction: column; }
      .dl-btn { justify-content: center; }
      .cta h2 { font-size: 1.8rem; }
      .features { overflow: visible; }
      .feat-fan {
        overflow-x: auto; scroll-snap-type: x mandatory;
        -webkit-overflow-scrolling: touch;
        justify-content: flex-start; align-items: stretch;
        padding: 1.5rem 1.25rem 2.5rem; gap: 0.75rem;
      }
      .fan-card { margin: 0; width: 200px; min-height: 220px; scroll-snap-align: center; }
      .fan-card:nth-child(n) { transform: none !important; }
      .fan-card.active { transform: none !important; box-shadow: var(--shadow-lg) !important; }
    }
    /* LIGHTBOX */
    .lightbox {
      display: none;
      position: fixed; inset: 0; z-index: 1000;
      align-items: center; justify-content: center;
    }
    .lightbox.open { display: flex; }
    .lightbox-backdrop {
      position: absolute; inset: 0;
      background: rgba(225, 237, 255, 0.78);
      backdrop-filter: blur(28px);
      -webkit-backdrop-filter: blur(28px);
    }
    .lightbox-close {
      position: absolute; top: 1.5rem; right: 1.5rem; z-index: 2;
      width: 46px; height: 46px; border-radius: 50%;
      background: rgba(0,0,0,0.07); border: 2px solid rgba(0,0,0,0.14);
      color: var(--text); cursor: pointer;
      display: flex; align-items: center; justify-content: center;
      transition: background 0.2s;
    }
    .lightbox-close:hover { background: rgba(0,0,0,0.14); }
    .lightbox-content {
      position: relative; z-index: 1;
      display: flex; flex-direction: column; gap: 1.5rem;
      width: min(920px, 92vw);
    }
    .lightbox-title {
      font-size: 1.75rem; font-weight: 900; color: var(--text);
    }
    .lightbox-body {
      display: flex; align-items: center; gap: 2.5rem;
    }
    .lightbox-arrow {
      flex-shrink: 0;
      width: 48px; height: 48px; border-radius: 50%;
      background: rgba(0,0,0,0.07); border: 2px solid rgba(0,0,0,0.14);
      color: var(--text); cursor: pointer;
      display: flex; align-items: center; justify-content: center;
      transition: background 0.2s;
    }
    .lightbox-arrow:hover { background: rgba(0,0,0,0.14); }
    .lightbox-video {
      max-height: 68vh; max-width: 42vw;
      border-radius: 24px;
      box-shadow: 0 20px 60px rgba(52,134,243,0.18), 0 4px 20px rgba(0,0,0,0.10);
      flex-shrink: 0;
    }
    .lightbox-info {
      flex: 1; display: flex; flex-direction: column; gap: 0.75rem;
    }
    .lightbox-desc {
      font-size: 1rem; color: #374151; line-height: 1.75;
    }
    /* FEEDBACK */
    .feedback {
      padding: 5rem 1.5rem;
      background: #ffffff;
      text-align: center;
    }
    .feedback-inner { max-width: 560px; margin: 0 auto; }
    .feedback-inner h2 { font-size: 2rem; font-weight: 900; color: var(--text); margin-bottom: 0.75rem; }
    .feedback-inner p { font-size: 1rem; color: #374151; line-height: 1.75; margin-bottom: 2rem; }
    .feedback-btn {
      display: inline-flex; align-items: center; gap: 0.6rem;
      padding: 0.9rem 2.2rem; border-radius: 14px;
      background: var(--text); color: white;
      font-family: 'Nunito', 'PingFang SC', sans-serif;
      font-weight: 800; font-size: 1rem;
      text-decoration: none;
      transition: transform 0.2s, box-shadow 0.2s;
      box-shadow: 0 4px 20px rgba(30,33,64,0.18);
    }
    .feedback-btn:hover { transform: translateY(-2px); box-shadow: 0 8px 32px rgba(30,33,64,0.28); }

    /* CONTACT */
    .contact { padding: 4rem 1.5rem; background: white; }
    .contact-inner { max-width: 600px; margin: 0 auto; text-align: center; }
    .contact-inner h2 { font-size: 2rem; font-weight: 900; color: var(--text); margin-bottom: 0.5rem; }
    .contact-inner p { font-size: 1rem; color: var(--muted); margin-bottom: 2.5rem; }
    .contact-links { display: flex; justify-content: center; gap: 1.25rem; flex-wrap: wrap; }
    .contact-card {
      display: flex; align-items: center; gap: 0.85rem;
      padding: 1rem 1.75rem; border-radius: 16px;
      text-decoration: none; font-weight: 700; font-size: 0.95rem;
      transition: transform 0.2s, box-shadow 0.2s;
      box-shadow: var(--shadow);
    }
    .contact-card:hover { transform: translateY(-3px); box-shadow: var(--shadow-lg); }
    .contact-card svg { flex-shrink: 0; }
    .contact-rednote { background: #ff2442; color: white; }
    .contact-linkedin { background: #0a66c2; color: white; }
    .contact-card-label { display: flex; flex-direction: column; text-align: left; }
    .contact-card-sub { font-size: 0.72rem; font-weight: 600; opacity: 0.85; line-height: 1; margin-bottom: 2px; }
    .contact-card-name { font-size: 1rem; font-weight: 800; line-height: 1.2; }
  </style>
</head>
<body>

  <div class="hero-area">
  <!-- NAV -->
  <nav class="nav">
    <div class="nav-inner">
      <a class="logo" href="/">
        <img src="/shared-pic/bun-white.svg" height="32" alt="BlotzTask" style="border-radius:10px;width:auto;" />
        BlotzTask
      </a>
      <button class="lang-btn" id="lang-toggle">
        <span id="lang-label">中文</span>
      </button>
    </div>
  </nav>

  <!-- HERO -->
  <section class="hero">
    <div class="blob blob-g"></div>
    <div class="blob blob-b"></div>
    <div class="hero-inner">
      <div class="hero-text">
       
        <h1 class="hero-title" id="hero-title">The AI-powered way to manage ADHD tasks!</h1>
        <p class="hero-sub" id="hero-sub">Use AI to tackle your daily tasks: Quick task generation&nbsp;•&nbsp;AI breakdown&nbsp;•&nbsp;Easy capture</p>
        <div class="hero-downloads">
          <a class="dl-btn dl-ios"
            href="https://apps.apple.com/au/app/blotztask-adhd-time-manager/id6752492404"
            target="_blank" rel="noopener noreferrer">
             <svg width="22" height="22" viewBox="0 0 24 24" fill="currentColor">
              <path d="M18.71 19.5c-.83 1.24-1.71 2.45-3.05 2.47-1.34.03-1.77-.79-3.29-.79-1.53 0-2 .77-3.27.82-1.31.05-2.3-1.32-3.14-2.53C4.25 17 2.94 12.45 4.7 9.39c.87-1.52 2.43-2.48 4.12-2.51 1.28-.02 2.5.87 3.29.87.78 0 2.26-1.07 3.8-.91.65.03 2.47.26 3.64 1.98-.09.06-2.17 1.28-2.15 3.81.03 3.02 2.65 4.03 2.68 4.04-.03.07-.42 1.44-1.38 2.83M13 3.5c.73-.83 1.94-1.46 2.94-1.5.13 1.17-.34 2.35-1.04 3.19-.69.85-1.83 1.51-2.95 1.42-.15-1.15.41-2.35 1.05-3.11z"/>
            </svg>
            <div>
              <span class="dl-small" id="dl-ios-s">Download on the</span>
              <span class="dl-big">App Store</span>
            </div>
          </a>
          <a class="dl-btn dl-and"
            href="https://play.google.com/store/apps/details?id=com.blotz.blotztask&hl=en"
            target="_blank" rel="noopener noreferrer">
            <svg width="22" height="22" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
              <g clip-path="url(#clip0_47_2)">
              <mask id="mask0_47_2" style="mask-type:luminance" maskUnits="userSpaceOnUse" x="0" y="0" width="24" height="24">
              <path d="M24 0H0V24H24V0Z" fill="white"/>
              </mask>
              <g mask="url(#mask0_47_2)">
              <path d="M21.3995 12.9508L16.8795 15.2108L13.6895 12.0208L16.9095 8.80078L21.3995 11.0508C22.1895 11.4408 22.1895 12.5608 21.3995 12.9508Z" stroke="white" stroke-width="1.5" stroke-miterlimit="10" stroke-linecap="round" stroke-linejoin="round"/>
              <path d="M2 9.06025V3.07026C2 2.27026 2.83 1.76024 3.55 2.11024L16.92 8.80024L13.7 12.0202L4.12 21.6003L3.54 21.8903C2.83 22.2403 2 21.7303 2 20.9303V13.5703" stroke="white" stroke-width="1.5" stroke-miterlimit="10" stroke-linecap="round" stroke-linejoin="round"/>
              <path d="M16.8891 15.2095L4.11914 21.5995L13.6991 12.0195L16.8891 15.2095Z" stroke="white" stroke-width="1.5" stroke-miterlimit="10" stroke-linecap="round" stroke-linejoin="round"/>
              <path d="M13.6998 12.0201L4.08984 2.41016" stroke="white" stroke-width="1.5" stroke-miterlimit="10" stroke-linecap="round" stroke-linejoin="round"/>
              <path d="M16.9206 15.2409L16.8906 15.2109" stroke="white" stroke-width="1.5" stroke-miterlimit="10" stroke-linecap="round" stroke-linejoin="round"/>
              </g>
              </g>
              <defs>
              <clipPath id="clip0_47_2">
              <rect width="24" height="24" fill="white"/>
              </clipPath>
              </defs>
            </svg>
            <div>
              <span class="dl-small" id="dl-and-s">Get it on</span>
              <span class="dl-big">Google Play</span>
            </div>
          </a>
        </div>
      </div>
      <div class="hero-phone">
        <div class="phone-wrap">
          <video
            id="hero-video"
            class="hero-video"
            src="/en-videos/ai-voice-video.MP4"
            autoplay
            muted
            loop
            playsinline
          ></video>
          <div class="phone-glow"></div>
        </div>
      </div>
    </div>
    <svg class="hero-wave" viewBox="0 0 1440 70" fill="none" xmlns="http://www.w3.org/2000/svg" preserveAspectRatio="none">
      <path d="M0 35 C360 70 720 0 1080 35 C1260 53 1380 22 1440 35 L1440 70 L0 70 Z" fill="#ffffff"/>
    </svg>
  </section>
  </div>

  <!-- FEATURES -->
  <section class="features">
    <div class="sec-inner">
      <div class="sec-head">
        <h2 id="feat-title">Key Features</h2>
        <p id="feat-sub">Everything you need to stay on top of your tasks</p>
      </div>
      <div class="feat-fan">

        <div class="fan-card" data-video="/en-videos/ai-voice-video.MP4">
          <div class="fan-icon"><Icon name="lucide:mic" /></div>
          <div class="fan-label" id="f1-title">Voice to Tasks</div>
          <div class="fan-desc" id="f1-desc">Generate tasks from your voice input. AI automatically breaks them down into manageable steps, with monthly &amp; weekly progress reports.</div>
        </div>

        <div class="fan-card" data-video="/en-videos/month-review.MP4">
          <div class="fan-icon"><Icon name="lucide:sparkles" /></div>
          <div class="fan-label" id="f2-title">AI Summarization</div>
          <div class="fan-desc" id="f2-desc">Let AI recap everything you've accomplished this week or month — see your progress at a glance.</div>
        </div>

        <div class="fan-card" data-video="/en-videos/gashapon-machine.MP4">
          <div class="fan-icon"><Icon name="lucide:dices" /></div>
          <div class="fan-label" id="f3-title">Gacha Machine</div>
          <div class="fan-desc" id="f3-desc">Can't decide where to start? Spin the Gacha to randomly pick your next task and break the freeze!</div>
        </div>

        <div class="fan-card" data-video="/en-videos/note.MP4">
          <div class="fan-icon"><Icon name="lucide:notebook-pen" /></div>
          <div class="fan-label" id="f4-title">Quick Notes</div>
